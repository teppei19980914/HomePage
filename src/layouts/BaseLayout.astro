---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import { site, common } from "../data/labels";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  publishedDate?: string;
  tags?: string[];
}

const {
  title,
  description = site.defaultDescription,
  ogType = "website",
  publishedDate,
  tags = [],
} = Astro.props;

const siteTitle = `${title} | ${site.titleSuffix}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(`${import.meta.env.BASE_URL}og-image.png`, Astro.site).toString();

// JSON-LD structured data
const jsonLd = ogType === "article"
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description,
      author: { "@type": "Person", name: site.name, url: Astro.site?.toString() },
      datePublished: publishedDate,
      url: canonicalUrl,
      keywords: tags.join(", "),
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: site.name,
      description,
      url: canonicalUrl,
      author: {
        "@type": "Person",
        name: site.name,
        jobTitle: site.role,
        url: Astro.site?.toString(),
        sameAs: [
          "https://github.com/teppei19980914",
          "https://qiita.com/teppei19980914",
          "https://www.wantedly.com/id/teppei_urata",
        ],
      },
    };
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="f_jGq-vRpKheGaLTbGylmxYO7tMV8xx9R4lUvNQMo3o" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {publishedDate && (
      <meta property="article:published_time" content={publishedDate} />
    )}
    {tags.length > 0 && (
      <meta name="keywords" content={tags.join(", ")} />
    )}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} Blog RSS`}
      href={`${import.meta.env.BASE_URL}rss.xml`}
    />

    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <title>{siteTitle}</title>
    <ClientRouter />

    <script is:inline>
      function applyTheme() {
        var saved = localStorage.getItem("theme");
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (saved === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      }
      applyTheme();
      document.addEventListener("astro:before-swap", function (e) {
        var saved = localStorage.getItem("theme");
        if (saved === "light") {
          e.newDocument.documentElement.classList.remove("dark");
        } else {
          e.newDocument.documentElement.classList.add("dark");
        }
      });
    </script>

    <noscript>
      <style>
        /* JS 無効環境では reveal アニメーションを無効化し、常時表示する */
        .reveal { opacity: 1 !important; transform: none !important; }
        .fade-in { opacity: 1 !important; transform: none !important; animation: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <div class="scroll-progress" id="scrollProgress"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <button id="scrollTop" class="scroll-top" aria-label={common.scrollTopLabel} type="button">&#8593;</button>

    <script is:inline>
      function initScrollEffects() {
        var bar = document.getElementById("scrollProgress");
        var topBtn = document.getElementById("scrollTop");

        window.addEventListener(
          "scroll",
          function () {
            var h = document.documentElement.scrollHeight - window.innerHeight;
            if (bar) {
              bar.style.width = h > 0 ? (window.scrollY / h) * 100 + "%" : "0%";
            }
            if (topBtn) {
              topBtn.classList.toggle("visible", window.scrollY > 300);
            }
          },
          { passive: true },
        );

        if (topBtn) {
          topBtn.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" });
          });
        }
        var reveals = document.querySelectorAll(".reveal");
        if (reveals.length === 0) return;
        // IntersectionObserver 非対応環境では全要素を即時表示
        if (typeof IntersectionObserver === "undefined") {
          reveals.forEach(function (el) { el.classList.add("visible"); });
          return;
        }
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          // threshold 0: 1px でも交差したら発火。
          // 長文ページで要素がビューポートより大きい場合に
          // 10% に到達せず発火しない問題を回避する。
          { threshold: 0, rootMargin: "0px 0px -10% 0px" },
        );
        reveals.forEach(function (el) {
          // 既にビューポート内にある要素は即座に visible 化（observer 登録漏れ対策）
          var rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add("visible");
          } else {
            observer.observe(el);
          }
        });
      }
      initScrollEffects();
      document.addEventListener("astro:after-swap", initScrollEffects);
    </script>

    <!-- Mermaid (client-side, lazy load only when needed) -->
    <script is:inline>
      function initMermaid() {
        var codes = document.querySelectorAll("pre > code.language-mermaid");
        if (codes.length === 0) return;
        var s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js";
        s.onload = function () {
          var isDark = document.documentElement.classList.contains("dark");
          window.mermaid.initialize({ startOnLoad: false, theme: isDark ? "dark" : "default" });
          codes.forEach(function (code) {
            var pre = code.parentElement;
            var div = document.createElement("div");
            div.className = "mermaid";
            div.textContent = code.textContent;
            pre.replaceWith(div);
          });
          window.mermaid.run();
        };
        document.body.appendChild(s);
      }
      initMermaid();
      document.addEventListener("astro:after-swap", initMermaid);
    </script>

    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "d882ef0019134c4eb5d6473c4396f90c"}'></script>
  </body>
</html>
