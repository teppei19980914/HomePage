---
import { getLabels, normalizeLocale, LOCALES, type Locale } from "../i18n";
import { localeUrl } from "../i18n/url";

const locale = normalizeLocale(Astro.currentLocale);
const t = getLabels(locale);

const navItems = [
  { label: t.nav.home, href: localeUrl(locale, "") },
  { label: t.nav.profile, href: localeUrl(locale, "profile/") },
  { label: t.nav.product, href: localeUrl(locale, "product/") },
  { label: t.nav.project, href: localeUrl(locale, "project/") },
  { label: t.nav.blog, href: localeUrl(locale, "blog/") },
  { label: t.nav.contact, href: localeUrl(locale, "contact/") },
];

const currentPath = Astro.url.pathname;

// 言語切替リンク
const base = import.meta.env.BASE_URL;
const stripped = currentPath.startsWith(base) ? currentPath.slice(base.length) : currentPath;
const neutralPath = stripped.replace(/^(ja|en)\//, "").replace(/^\//, "");
const languageLinks: { loc: Locale; label: string; href: string }[] = LOCALES.map((loc) => ({
  loc,
  label: loc === "ja" ? "日本語" : "English",
  href: localeUrl(loc, neutralPath),
}));
---

<header class="header">
  <nav class="nav">
    <!-- ハンバーガーボタン（モバイル） -->
    <button
      id="menuToggle"
      class="menu-toggle"
      aria-label={t.nav.menuOpen}
      aria-expanded="false"
      type="button"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <!-- PC: 横並びナビ -->
    <ul class="nav-links">
      {
        navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[{ active: currentPath === href }]}
              data-astro-reload={href.includes("blog") ? true : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- 右端: 言語切替 + テーマ切替（常時表示） -->
    <div class="header-actions">
      <div class="lang-switcher" role="group" aria-label={t.languageSwitcher.label}>
        {
          languageLinks.map(({ loc, label, href }) => (
            <a
              href={href}
              hreflang={loc}
              class:list={["lang-link", { active: loc === locale }]}
              aria-current={loc === locale ? "true" : undefined}
              data-astro-reload
            >
              {label}
            </a>
          ))
        }
      </div>
      <button
        id="themeToggle"
        class="theme-toggle"
        aria-label={t.nav.themeToggleLabel}
        type="button"
      >
        <span class="icon-sun">&#9788;</span>
        <span class="icon-moon">&#9790;</span>
      </button>
    </div>
  </nav>

  <!-- モバイルメニュー（展開時） -->
  <div id="mobileMenu" class="mobile-menu" aria-hidden="true">
    <ul class="mobile-nav-links">
      {
        navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={["mobile-nav-link", { active: currentPath === href }]}
              data-astro-reload={href.includes("blog") ? true : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script is:inline>
  function initHeader() {
    var toggle = document.getElementById("menuToggle");
    var menu = document.getElementById("mobileMenu");
    if (!toggle || !menu) return;

    toggle.addEventListener("click", function () {
      var isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
      menu.setAttribute("aria-hidden", isOpen ? "true" : "false");
      toggle.classList.toggle("is-open", !isOpen);
    });

    // メニュー内リンクをクリックしたら閉じる
    menu.querySelectorAll("a").forEach(function (link) {
      link.addEventListener("click", function () {
        toggle.setAttribute("aria-expanded", "false");
        menu.setAttribute("aria-hidden", "true");
        toggle.classList.remove("is-open");
      });
    });
  }

  function initThemeToggle() {
    var btn = document.getElementById("themeToggle");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }

  function initLangSwitcher() {
    var links = document.querySelectorAll(".lang-link");
    links.forEach(function (link) {
      link.addEventListener("click", function () {
        var lang = link.getAttribute("hreflang");
        if (lang === "ja" || lang === "en") {
          try { localStorage.setItem("preferred-locale", lang); } catch (e) { /* ignore */ }
        }
      });
    });
  }

  initHeader();
  initThemeToggle();
  initLangSwitcher();
  document.addEventListener("astro:after-swap", function () {
    initHeader();
    initThemeToggle();
    initLangSwitcher();
  });
</script>

<style>
  .header {
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    background-color: color-mix(in srgb, var(--color-surface) 85%, transparent);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background-color 0.3s, border-color 0.3s;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.75rem;
  }

  /* ===== ハンバーガーボタン（モバイルのみ表示） ===== */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
  }
  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }
  /* X アニメーション */
  .menu-toggle.is-open .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-toggle.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ===== PC ナビリンク ===== */
  .nav-links {
    list-style: none;
    display: flex;
    gap: 0;
    padding: 0;
    margin: 0;
    flex: 1;
  }
  .nav-links li {
    flex-shrink: 0;
  }
  .nav-links a {
    display: block;
    padding: 0.85rem 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    background-image: none;
    white-space: nowrap;
    position: relative;
    transition: color 0.2s;
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transition: transform 0.25s;
  }
  .nav-links a:hover::after,
  .nav-links a.active::after {
    transform: scaleX(1);
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-primary);
  }

  /* ===== 右端アクション ===== */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin-left: auto;
  }
  .lang-switcher {
    display: flex;
    gap: 0.2rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.15rem;
  }
  .lang-link {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background-image: none;
    border-radius: 9999px;
    white-space: nowrap;
    transition: color 0.2s, background-color 0.2s;
  }
  .lang-link:hover { color: var(--color-primary); }
  .lang-link.active {
    color: var(--color-surface);
    background-color: var(--color-primary);
  }
  :global(.dark) .lang-link.active { color: #0f172a; }
  .theme-toggle {
    flex-shrink: 0;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: var(--color-text-muted);
    transition: border-color 0.2s, color 0.2s, transform 0.3s;
  }
  .theme-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: rotate(30deg);
  }
  .icon-moon { display: none; }
  :global(.dark) .icon-sun { display: none; }
  :global(.dark) .icon-moon { display: inline; }

  /* ===== モバイルメニュー（ドロップダウン） ===== */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-surface);
    transition: background-color 0.3s;
  }
  .mobile-nav-links {
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
  }
  .mobile-nav-link {
    display: block;
    padding: 0.75rem 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    background-image: none;
    transition: color 0.2s, background-color 0.2s;
  }
  .mobile-nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-glow);
  }
  .mobile-nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* ===== レスポンシブ ===== */
  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }
    .nav-links {
      display: none;
    }
    .mobile-menu[aria-hidden="false"] {
      display: block;
    }
  }
</style>
