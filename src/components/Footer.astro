---
import { footer } from "../data/labels";
const year = new Date().getFullYear();
---

<footer class="footer">
  <p>&copy; {year} {footer.copyright}</p>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    transition: border-color 0.3s, color 0.3s;
  }
</style>
