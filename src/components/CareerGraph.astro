---
import { about, careerGraph } from "../data/labels";
---

<div class="career-graph-wrapper">
  <div class="career-legend">
    <span class="legend-item">
      <span class="legend-dot" style="background:#2563eb"></span>{about.career.legend.employee}
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#06b6d4"></span>{about.career.legend.personal}
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#8b5cf6"></span>{about.career.legend.sideJob}
    </span>
  </div>

  <div class="cg-graph">
    <svg class="cg-svg" viewBox="0 0 460 720" preserveAspectRatio="xMidYMin meet" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Main line -->
      <line x1="200" y1="30" x2="200" y2="90" class="cg-line-main" />
      <line x1="200" y1="90" x2="200" y2="430" class="cg-line-main" />
      <line x1="200" y1="430" x2="200" y2="720" class="cg-line-main" />

      <!-- Merge curves -->
      <path d="M120,160 C120,120 200,120 200,90" class="cg-line-personal" />
      <path d="M280,160 C280,120 200,120 200,90" class="cg-line-side" />

      <!-- Branch vertical -->
      <line x1="120" y1="160" x2="120" y2="370" class="cg-line-personal" />
      <line x1="280" y1="160" x2="280" y2="310" class="cg-line-side" />

      <!-- Fork curves -->
      <path d="M200,430 C200,400 120,400 120,370" class="cg-line-personal" />
      <path d="M200,430 C200,400 280,400 280,310" class="cg-line-side" />

      <!-- Nodes -->
      <circle cx="200" cy="30" r="8" class="cg-dot-main cg-dot-big" />
      <circle cx="200" cy="90" r="5" class="cg-dot-main" />
      <circle cx="200" cy="430" r="6" class="cg-dot-main cg-dot-fork" />
      <circle cx="200" cy="490" r="4" class="cg-dot-main" />
      <circle cx="200" cy="540" r="4" class="cg-dot-main" />
      <circle cx="200" cy="590" r="4" class="cg-dot-main" />
      <circle cx="200" cy="640" r="4" class="cg-dot-main" />
      <circle cx="200" cy="700" r="8" class="cg-dot-main cg-dot-big" />
      <circle cx="120" cy="220" r="4" class="cg-dot-personal" />
      <circle cx="120" cy="300" r="4" class="cg-dot-personal" />
      <circle cx="280" cy="220" r="4" class="cg-dot-side" />

      <!-- Labels inside SVG for proper scaling -->
      <text x="215" y="36" class="cg-svg-text cg-svg-text-bold">{about.career.now}</text>

      <!-- Personal Dev (left) -->
      <text x="110" y="218" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[0].name}</text>
      <text x="110" y="233" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[0].date}</text>
      <text x="110" y="298" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[1].name}</text>
      <text x="110" y="313" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[1].date}</text>

      <!-- Side Business (right) -->
      <text x="295" y="218" class="cg-svg-text">{careerGraph.sideBusiness.name}</text>
      <text x="295" y="233" class="cg-svg-text-small cg-svg-text-purple">{careerGraph.sideBusiness.date} {careerGraph.sideBusiness.suffix}</text>

      <!-- Fork label -->
      <text x="215" y="435" class="cg-svg-text-small cg-svg-text-muted">{about.career.branchLabel}</text>

      <!-- Career history (right of main) -->
      <text x="215" y="495" class="cg-svg-text">{careerGraph.history[0].name}</text>
      <text x="215" y="510" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[0].dateSuffix}</text>
      <text x="215" y="545" class="cg-svg-text">{careerGraph.history[1].name}</text>
      <text x="215" y="560" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[1].dateSuffix}</text>
      <text x="215" y="595" class="cg-svg-text">{careerGraph.history[2].name}</text>
      <text x="215" y="610" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[2].dateSuffix}</text>
      <text x="215" y="645" class="cg-svg-text">{careerGraph.history[3].name}</text>
      <text x="215" y="660" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[3].dateSuffix}</text>
      <text x="215" y="705" class="cg-svg-text">{careerGraph.history[4].name}</text>
      <text x="215" y="720" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[4].dateSuffix}</text>
    </svg>
  </div>
</div>

<style is:global>
  .career-graph-wrapper {
    margin-top: 1rem;
  }

  .career-legend {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  /* Graph: SVG scales with container */
  .cg-graph {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    aspect-ratio: 460 / 720;
  }

  .cg-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Lines */
  .cg-line-main { stroke: #2563eb; stroke-width: 3; }
  .cg-line-personal { stroke: #06b6d4; stroke-width: 3; fill: none; }
  .cg-line-side { stroke: #8b5cf6; stroke-width: 3; fill: none; }

  /* Dots */
  .cg-dot-main { fill: #2563eb; stroke: var(--color-bg); stroke-width: 2; }
  .cg-dot-big { stroke-width: 3; filter: drop-shadow(0 0 6px rgba(37, 99, 235, 0.4)); }
  .cg-dot-fork { fill: #2563eb; stroke: var(--color-bg); stroke-width: 2; filter: drop-shadow(0 0 8px rgba(37, 99, 235, 0.5)); }
  .cg-dot-personal { fill: #06b6d4; stroke: var(--color-bg); stroke-width: 2; }
  .cg-dot-side { fill: #8b5cf6; stroke: var(--color-bg); stroke-width: 2; }

  /* SVG text */
  .cg-svg-text {
    font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif;
    font-size: 13px;
    fill: var(--color-text);
  }

  .cg-svg-text-bold {
    font-weight: 700;
    font-size: 15px;
  }

  .cg-svg-text-small {
    font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif;
    font-size: 10px;
    fill: var(--color-text-muted);
  }

  .cg-svg-text-muted { fill: var(--color-text-muted); }
  .cg-svg-text-cyan { fill: #06b6d4; }
  .cg-svg-text-purple { fill: #8b5cf6; }
</style>
