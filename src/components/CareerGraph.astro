---
const isDark = false; // SSR default, JS will adjust
---

<div class="career-graph-wrapper">
  <div class="career-legend">
    <span class="legend-item">
      <span class="legend-dot" style="background:#2563eb"></span>正社員
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#06b6d4"></span>個人開発
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#8b5cf6"></span>副業
    </span>
  </div>

  <div class="cg-graph">
    <svg class="cg-svg" viewBox="0 0 400 720" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Main line (blue): top to fork, then fork to bottom -->
      <line x1="200" y1="30" x2="200" y2="90" class="cg-line-main" />
      <line x1="200" y1="90" x2="200" y2="430" class="cg-line-main" />
      <line x1="200" y1="430" x2="200" y2="720" class="cg-line-main" />

      <!-- === UPPER: Merge curves (branches → main at 現在) === -->
      <!-- personal-dev merges into main -->
      <path d="M120,160 C120,120 200,120 200,90" class="cg-line-personal" />
      <!-- side-business merges into main -->
      <path d="M280,160 C280,120 200,120 200,90" class="cg-line-side" />

      <!-- === Branch vertical lines === -->
      <!-- personal-dev vertical -->
      <line x1="120" y1="160" x2="120" y2="370" class="cg-line-personal" />
      <!-- side-business vertical -->
      <line x1="280" y1="160" x2="280" y2="310" class="cg-line-side" />

      <!-- === LOWER: Fork curves (main → branches) === -->
      <!-- main forks to personal-dev (left) -->
      <path d="M200,430 C200,400 120,400 120,370" class="cg-line-personal" />
      <!-- main forks to side-business (right) -->
      <path d="M200,430 C200,400 280,400 280,310" class="cg-line-side" />

      <!-- === Nodes === -->
      <!-- Main: 現在 (top) -->
      <circle cx="200" cy="30" r="8" class="cg-dot-main cg-dot-big" />
      <!-- Main: merge point -->
      <circle cx="200" cy="90" r="5" class="cg-dot-main" />
      <!-- Main: fork point -->
      <circle cx="200" cy="430" r="6" class="cg-dot-main cg-dot-fork" />
      <!-- Main: career history -->
      <circle cx="200" cy="490" r="4" class="cg-dot-main" />
      <circle cx="200" cy="540" r="4" class="cg-dot-main" />
      <circle cx="200" cy="590" r="4" class="cg-dot-main" />
      <circle cx="200" cy="640" r="4" class="cg-dot-main" />
      <circle cx="200" cy="700" r="8" class="cg-dot-main cg-dot-big" />

      <!-- Personal Dev nodes -->
      <circle cx="120" cy="220" r="4" class="cg-dot-personal" />
      <circle cx="120" cy="300" r="4" class="cg-dot-personal" />

      <!-- Side Business nodes -->
      <circle cx="280" cy="220" r="4" class="cg-dot-side" />
    </svg>

    <!-- Labels -->
    <div class="cg-labels">
      <!-- 現在 -->
      <div class="cg-label" style="top: 20px">
        <span class="cg-tag">now</span>
        <span class="cg-text cg-text-bold">現在</span>
      </div>

      <!-- Personal Dev labels (left side) -->
      <div class="cg-label cg-label-left" style="top: 210px">
        <span class="cg-text">ユメログ</span>
        <span class="cg-tag cg-tag-personal">2026.03</span>
      </div>
      <div class="cg-label cg-label-left" style="top: 290px">
        <span class="cg-text">MindFlow</span>
        <span class="cg-tag cg-tag-personal">2026.01</span>
      </div>

      <!-- Side Business labels (right side) -->
      <div class="cg-label cg-label-right" style="top: 210px">
        <span class="cg-tag cg-tag-side">2026.03</span>
        <span class="cg-text">WakuLab — 業務委託</span>
      </div>

      <!-- Fork point -->
      <div class="cg-label" style="top: 420px">
        <span class="cg-fork-label">branch</span>
      </div>

      <!-- Career history -->
      <div class="cg-label" style="top: 480px">
        <span class="cg-tag">2025.05</span>
        <span class="cg-text">LTS ソフトウェアテクノロジー 入社</span>
      </div>
      <div class="cg-label" style="top: 530px">
        <span class="cg-tag">2025.04</span>
        <span class="cg-text">インプリム 退職</span>
      </div>
      <div class="cg-label" style="top: 580px">
        <span class="cg-tag">2023.01</span>
        <span class="cg-text">インプリム 入社 — Pleasanter</span>
      </div>
      <div class="cg-label" style="top: 630px">
        <span class="cg-tag">2022.12</span>
        <span class="cg-text">アクモス 退職</span>
      </div>
      <div class="cg-label" style="top: 690px">
        <span class="cg-tag">2021.04</span>
        <span class="cg-text">キャリアスタート</span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .career-graph-wrapper {
    margin-top: 1rem;
  }

  .career-legend {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  /* Graph container */
  .cg-graph {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    height: 750px;
  }

  .cg-svg {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 720px;
  }

  /* Lines */
  .cg-line-main {
    stroke: #2563eb;
    stroke-width: 3;
  }

  .cg-line-personal {
    stroke: #06b6d4;
    stroke-width: 3;
    fill: none;
  }

  .cg-line-side {
    stroke: #8b5cf6;
    stroke-width: 3;
    fill: none;
  }

  /* Dots */
  .cg-dot-main {
    fill: #2563eb;
    stroke: var(--color-bg);
    stroke-width: 2;
  }

  .cg-dot-big {
    stroke-width: 3;
    filter: drop-shadow(0 0 6px rgba(37, 99, 235, 0.4));
  }

  .cg-dot-fork {
    fill: #2563eb;
    stroke: var(--color-bg);
    stroke-width: 2;
    filter: drop-shadow(0 0 8px rgba(37, 99, 235, 0.5));
  }

  .cg-dot-personal {
    fill: #06b6d4;
    stroke: var(--color-bg);
    stroke-width: 2;
  }

  .cg-dot-side {
    fill: #8b5cf6;
    stroke: var(--color-bg);
    stroke-width: 2;
  }

  /* Labels */
  .cg-labels {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .cg-label {
    position: absolute;
    left: calc(50% + 30px);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .cg-label-left {
    left: auto;
    right: calc(50% + 30px);
    flex-direction: row-reverse;
  }

  .cg-label-right {
    left: calc(50% + 50px);
  }

  .cg-tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 0.25rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: background-color 0.3s, border-color 0.3s;
  }

  .cg-text {
    font-size: 0.85rem;
  }

  .cg-text-bold {
    font-weight: 700;
    font-size: 1rem;
  }

  .cg-tag-personal {
    border-color: rgba(6, 182, 212, 0.3);
    color: #06b6d4;
  }

  .cg-tag-side {
    border-color: rgba(139, 92, 246, 0.3);
    color: #8b5cf6;
  }

  .cg-fork-label {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    font-family: monospace;
  }
</style>
