---
import { about, careerGraph } from "../data/labels";
---

<div class="career-graph-wrapper">
  <div class="career-legend">
    <span class="legend-item">
      <span class="legend-dot" style="background:#2563eb"></span>{about.career.legend.employee}
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#06b6d4"></span>{about.career.legend.personal}
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#8b5cf6"></span>{about.career.legend.sideJob}
    </span>
  </div>

  <div class="cg-graph">
    <svg class="cg-svg" viewBox="0 0 380 620" preserveAspectRatio="xMidYMin meet" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Main line (center = 110) -->
      <line x1="110" y1="25" x2="110" y2="70" class="cg-line-main" />
      <line x1="110" y1="70" x2="110" y2="340" class="cg-line-main" />
      <line x1="110" y1="340" x2="110" y2="600" class="cg-line-main" />

      <!-- Merge curves -->
      <path d="M55,125 C55,95 110,95 110,70" class="cg-line-personal" />
      <path d="M165,125 C165,95 110,95 110,70" class="cg-line-side" />

      <!-- Branch vertical -->
      <line x1="55" y1="125" x2="55" y2="290" class="cg-line-personal" />
      <line x1="165" y1="125" x2="165" y2="240" class="cg-line-side" />

      <!-- Fork curves -->
      <path d="M110,340 C110,315 55,315 55,290" class="cg-line-personal" />
      <path d="M110,340 C110,315 165,315 165,240" class="cg-line-side" />

      <!-- Nodes -->
      <circle cx="110" cy="25" r="7" class="cg-dot-main cg-dot-big" />
      <circle cx="110" cy="70" r="4" class="cg-dot-main" />
      <circle cx="110" cy="340" r="5" class="cg-dot-main cg-dot-fork" />
      <circle cx="110" cy="390" r="3" class="cg-dot-main" />
      <circle cx="110" cy="435" r="3" class="cg-dot-main" />
      <circle cx="110" cy="480" r="3" class="cg-dot-main" />
      <circle cx="110" cy="525" r="3" class="cg-dot-main" />
      <circle cx="110" cy="580" r="7" class="cg-dot-main cg-dot-big" />
      <circle cx="55" cy="175" r="3" class="cg-dot-personal" />
      <circle cx="55" cy="240" r="3" class="cg-dot-personal" />
      <circle cx="165" cy="175" r="3" class="cg-dot-side" />

      <!-- Labels -->
      <text x="125" y="30" class="cg-svg-text cg-svg-text-bold">{about.career.now}</text>

      <!-- Personal Dev (left) -->
      <text x="45" y="173" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[0].name}</text>
      <text x="45" y="188" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[0].date}</text>
      <text x="45" y="238" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[1].name}</text>
      <text x="45" y="253" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[1].date}</text>

      <!-- Side Business (right) -->
      <text x="178" y="173" class="cg-svg-text">{careerGraph.sideBusiness.name}</text>
      <text x="178" y="188" class="cg-svg-text-small cg-svg-text-purple">{careerGraph.sideBusiness.date} {careerGraph.sideBusiness.suffix}</text>

      <!-- Fork label -->
      <text x="125" y="345" class="cg-svg-text-small cg-svg-text-muted">{about.career.branchLabel}</text>

      <!-- Career history -->
      <text x="125" y="388" class="cg-svg-text">{careerGraph.history[0].name}</text>
      <text x="125" y="403" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[0].dateSuffix}</text>
      <text x="125" y="433" class="cg-svg-text">{careerGraph.history[1].name}</text>
      <text x="125" y="448" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[1].dateSuffix}</text>
      <text x="125" y="478" class="cg-svg-text">{careerGraph.history[2].name}</text>
      <text x="125" y="493" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[2].dateSuffix}</text>
      <text x="125" y="523" class="cg-svg-text">{careerGraph.history[3].name}</text>
      <text x="125" y="538" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[3].dateSuffix}</text>
      <text x="125" y="578" class="cg-svg-text">{careerGraph.history[4].name}</text>
      <text x="125" y="593" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[4].dateSuffix}</text>
    </svg>
  </div>
</div>

<style is:global>
  .career-graph-wrapper {
    margin-top: 1rem;
  }

  .career-legend {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .cg-graph {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    aspect-ratio: 380 / 620;
  }

  .cg-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Lines */
  .cg-line-main { stroke: #2563eb; stroke-width: 3; }
  .cg-line-personal { stroke: #06b6d4; stroke-width: 3; fill: none; }
  .cg-line-side { stroke: #8b5cf6; stroke-width: 3; fill: none; }

  /* Dots */
  .cg-dot-main { fill: #2563eb; stroke: var(--color-bg); stroke-width: 2; }
  .cg-dot-big { stroke-width: 3; filter: drop-shadow(0 0 6px rgba(37, 99, 235, 0.4)); }
  .cg-dot-fork { fill: #2563eb; stroke: var(--color-bg); stroke-width: 2; filter: drop-shadow(0 0 8px rgba(37, 99, 235, 0.5)); }
  .cg-dot-personal { fill: #06b6d4; stroke: var(--color-bg); stroke-width: 2; }
  .cg-dot-side { fill: #8b5cf6; stroke: var(--color-bg); stroke-width: 2; }

  /* SVG text */
  .cg-svg-text {
    font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif;
    font-size: 11px;
    fill: var(--color-text);
  }

  .cg-svg-text-bold {
    font-weight: 700;
    font-size: 13px;
  }

  .cg-svg-text-small {
    font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif;
    font-size: 9px;
    fill: var(--color-text-muted);
  }

  .cg-svg-text-muted { fill: var(--color-text-muted); }
  .cg-svg-text-cyan { fill: #06b6d4; }
  .cg-svg-text-purple { fill: #8b5cf6; }
</style>
