---
import { getLabels, normalizeLocale } from "../i18n";

// 親ページから locale を渡せる。未指定時は Astro.currentLocale を使用する。
interface Props {
  locale?: string;
}
const { locale: localeProp } = Astro.props;
const locale = normalizeLocale(localeProp ?? Astro.currentLocale);
const t = getLabels(locale);
const { about, careerGraph } = t;
---

<div class="career-graph-wrapper">
  <div class="career-legend">
    <span class="legend-item">
      <span class="legend-dot" style="background:#2563eb"></span>{about.career.legend.employee}
    </span>
    <span class="legend-item">
      <span class="legend-dot" style="background:#06b6d4"></span>{about.career.legend.personal}
    </span>
  </div>

  <div class="cg-graph">
    <svg class="cg-svg" viewBox="-40 0 420 680" preserveAspectRatio="xMidYMin meet" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Main line (center = 110) -->
      <line x1="110" y1="25" x2="110" y2="70" class="cg-line-main" />
      <line x1="110" y1="70" x2="110" y2="360" class="cg-line-main" />
      <line x1="110" y1="360" x2="110" y2="660" class="cg-line-main" />

      <!-- Merge curves (personal dev) -->
      <path d="M55,125 C55,95 110,95 110,70" class="cg-line-personal" />

      <!-- Branch vertical (personal dev) -->
      <line x1="55" y1="125" x2="55" y2="310" class="cg-line-personal" />

      <!-- Fork curves (personal dev) -->
      <path d="M110,360 C110,335 55,335 55,310" class="cg-line-personal" />

      <!-- Nodes -->
      <circle cx="110" cy="25" r="7" class="cg-dot-main cg-dot-big" />
      <circle cx="110" cy="70" r="4" class="cg-dot-main" />
      <circle cx="110" cy="360" r="5" class="cg-dot-main cg-dot-fork" />
      <circle cx="110" cy="410" r="3" class="cg-dot-main" />
      <circle cx="110" cy="455" r="3" class="cg-dot-main" />
      <circle cx="110" cy="500" r="3" class="cg-dot-main" />
      <circle cx="110" cy="545" r="3" class="cg-dot-main" />
      <circle cx="110" cy="640" r="7" class="cg-dot-main cg-dot-big" />
      <circle cx="55" cy="155" r="3" class="cg-dot-personal" />
      <circle cx="55" cy="215" r="3" class="cg-dot-personal" />
      <circle cx="55" cy="275" r="3" class="cg-dot-personal" />

      <!-- Labels -->
      <text x="125" y="30" class="cg-svg-text cg-svg-text-bold">{about.career.now}</text>

      <!-- Personal Dev (left) -->
      <text x="45" y="153" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[0].name}</text>
      <text x="45" y="168" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[0].date}</text>
      <text x="45" y="213" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[1].name}</text>
      <text x="45" y="228" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[1].date}</text>
      <text x="45" y="273" text-anchor="end" class="cg-svg-text">{careerGraph.personalDev[2].name}</text>
      <text x="45" y="288" text-anchor="end" class="cg-svg-text-small cg-svg-text-cyan">{careerGraph.personalDev[2].date}</text>

      <!-- Fork label -->
      <text x="125" y="365" class="cg-svg-text-small cg-svg-text-muted">{about.career.branchLabel}</text>

      <!-- Career history -->
      <text x="125" y="408" class="cg-svg-text">{careerGraph.history[0].name}</text>
      <text x="125" y="423" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[0].dateSuffix}</text>
      <text x="125" y="453" class="cg-svg-text">{careerGraph.history[1].name}</text>
      <text x="125" y="468" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[1].dateSuffix}</text>
      <text x="125" y="498" class="cg-svg-text">{careerGraph.history[2].name}</text>
      <text x="125" y="513" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[2].dateSuffix}</text>
      <text x="125" y="543" class="cg-svg-text">{careerGraph.history[3].name}</text>
      <text x="125" y="558" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[3].dateSuffix}</text>
      <text x="125" y="638" class="cg-svg-text">{careerGraph.history[4].name}</text>
      <text x="125" y="653" class="cg-svg-text-small cg-svg-text-muted">{careerGraph.history[4].dateSuffix}</text>
    </svg>
  </div>
</div>

<style is:global>
  .career-graph-wrapper {
    margin-top: 1rem;
  }

  .career-legend {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .cg-graph {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    aspect-ratio: 420 / 680;
  }

  .cg-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Lines */
  .cg-line-main { stroke: #2563eb; stroke-width: 3; }
  .cg-line-personal { stroke: #06b6d4; stroke-width: 3; fill: none; }
  .cg-line-side { stroke: #8b5cf6; stroke-width: 3; fill: none; }

  /* Dots */
  .cg-dot-main { fill: #2563eb; stroke: var(--color-bg); stroke-width: 2; }
  .cg-dot-big { stroke-width: 3; filter: drop-shadow(0 0 6px rgba(37, 99, 235, 0.4)); }
  .cg-dot-fork { fill: #2563eb; stroke: var(--color-bg); stroke-width: 2; filter: drop-shadow(0 0 8px rgba(37, 99, 235, 0.5)); }
  .cg-dot-personal { fill: #06b6d4; stroke: var(--color-bg); stroke-width: 2; }
  .cg-dot-side { fill: #8b5cf6; stroke: var(--color-bg); stroke-width: 2; }

  /* SVG text */
  .cg-svg-text {
    font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif;
    font-size: 11px;
    fill: var(--color-text);
  }

  .cg-svg-text-bold {
    font-weight: 700;
    font-size: 13px;
  }

  .cg-svg-text-small {
    font-family: "Helvetica Neue", Arial, "Hiragino Sans", sans-serif;
    font-size: 9px;
    fill: var(--color-text-muted);
  }

  .cg-svg-text-muted { fill: var(--color-text-muted); }
  .cg-svg-text-cyan { fill: #06b6d4; }
  .cg-svg-text-purple { fill: #8b5cf6; }
</style>
