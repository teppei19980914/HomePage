---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { project as projectLabels } from "../../data/labels";

const projects = (await getCollection("project"))
  .sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout title={projectLabels.title} description={projectLabels.description}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{projectLabels.title}</h1>
    <p class="page-subtitle fade-in delay-1">
      {projectLabels.subtitle}
    </p>
  </div>

  {
    projects.length === 0 ? (
      <p>{projectLabels.emptyMessage}</p>
    ) : (
      <div class="project-list">
        {projects.map((project, i) => (
          <article
            class="project-card reveal"
            style={`transition-delay: ${i * 0.15}s`}
          >
            <div class="project-card-header">
              <div class="project-card-meta">
                <span
                  class={`contract-badge contract-${project.data.contractType}`}
                >
                  {project.data.contractType === "employee"
                    ? projectLabels.contractTypes.employee
                    : projectLabels.contractTypes.contract}
                </span>
                <span class="period">{project.data.period}</span>
              </div>
              <h2>{project.data.title}</h2>
              <p class="company">
                {project.data.companyUrl ? (
                  <a
                    href={project.data.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {project.data.company}
                  </a>
                ) : (
                  project.data.company
                )}
                <span class="role">/ {project.data.role}</span>
              </p>
              <p class="description">{project.data.description}</p>
              <div class="tags">
                {project.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="project-card-actions">
              <a
                href={`${import.meta.env.BASE_URL}project/${project.id}/`}
                class="btn-detail"
              >
                {projectLabels.detailLink} &rarr;
              </a>
            </div>
          </article>
        ))}
      </div>
    )
  }
</BaseLayout>

<style>
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s,
      background-color 0.3s;
  }

  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--color-primary);
  }

  :global(.dark) .project-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .project-card-header {
    padding: 1.5rem 1.5rem 1rem;
  }

  .project-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .contract-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contract-employee {
    background-color: rgba(37, 99, 235, 0.15);
    color: var(--color-primary);
  }

  .contract-contract {
    background-color: rgba(139, 92, 246, 0.15);
    color: #7c3aed;
  }

  :global(.dark) .contract-contract {
    color: #a78bfa;
  }

  .period {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .project-card h2 {
    font-size: 1.35rem;
    margin-bottom: 0.25rem;
  }

  .company {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .role {
    margin-left: 0.25rem;
  }

  .description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .project-card-actions {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .btn-detail {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    background-image: none;
    transition: transform 0.25s, background-color 0.25s, color 0.25s;
  }

  .btn-detail:hover {
    background-color: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }
</style>
