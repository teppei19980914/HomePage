---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { common, project as projectLabels } from "../../data/labels";

export async function getStaticPaths() {
  const projects = await getCollection("project");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="prose">
    <header class="hero-gradient fade-in">
      <div class="header-meta">
        <span class={`contract-badge contract-${project.data.contractType}`}>
          {project.data.contractType === "employee" ? projectLabels.contractTypes.employee : projectLabels.contractTypes.contract}
        </span>
        <span class="period">{project.data.period}</span>
      </div>
      <h1>{project.data.title}</h1>
      <p class="company">
        {
          project.data.companyUrl ? (
            <a
              href={project.data.companyUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              {project.data.company}
            </a>
          ) : (
            project.data.company
          )
        }
        <span class="role">/ {project.data.role}</span>
      </p>
      <p class="description">{project.data.description}</p>
      <div class="tags">
        {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </header>
    <div class="content reveal">
      <Content />
    </div>
  </article>
  <section class="bottom-cta reveal">
    <h2>{common.ctaTitle}</h2>
    <p>{common.ctaBody}</p>
    <a href={`${import.meta.env.BASE_URL}contact/`} class="btn-cta">{common.ctaButton}</a>
  </section>
  <nav class="back reveal">
    <a href="#" onclick="history.back(); return false;">&larr; {common.backLink}</a>
  </nav>
</BaseLayout>

<style>
  header {
    margin-bottom: 2rem;
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .contract-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
  }

  .contract-employee {
    background-color: rgba(37, 99, 235, 0.15);
    color: var(--color-primary);
  }

  .contract-contract {
    background-color: rgba(139, 92, 246, 0.15);
    color: #7c3aed;
  }

  :global(.dark) .contract-contract {
    color: #a78bfa;
  }

  .period {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .company {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .role {
    margin-left: 0.25rem;
  }

  .description {
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .content {
    margin-top: 2rem;
  }

  .back {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .bottom-cta { margin-top: 3rem; padding: 2.5rem 1.5rem; text-align: center; border: 1px solid var(--color-border); border-radius: 0.75rem; background-color: var(--color-surface); }
  .bottom-cta h2 { margin-bottom: 0.5rem; }
  .bottom-cta p { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  .btn-cta { display: inline-block; padding: 0.75rem 2rem; border-radius: 9999px; background: linear-gradient(135deg, var(--color-primary), #8b5cf6); color: white; font-weight: 600; background-image: none; transition: transform 0.25s, box-shadow 0.25s; }
  .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(--color-primary-glow); color: white; }
</style>
