---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { product } from "../../data/labels";

const products = (await getCollection("product"))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={product.title} description={product.description}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{product.title}</h1>
    <p class="page-subtitle fade-in delay-1">
      {product.subtitle}
    </p>
  </div>

  {
    products.length === 0 ? (
      <p>プロダクトはまだありません。</p>
    ) : (
      <div class="product-list">
        {products.map((product, i) => (
          <article
            class="product-card reveal"
            style={`transition-delay: ${i * 0.15}s`}
          >
            <div class="product-card-header">
              <div class="product-card-meta">
                <span class={`status status-${product.data.status}`}>
                  {product.data.status === "active"
                    ? "Active"
                    : product.data.status === "beta"
                      ? "Beta"
                      : "Archived"}
                </span>
              </div>
              <h2>{product.data.title}</h2>
              <p class="product-tagline">{product.data.tagline}</p>
              <p class="product-description">{product.data.description}</p>
              <div class="tags">
                {product.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="product-card-actions">
              <a
                href={`${import.meta.env.BASE_URL}product/${product.id}/`}
                class="btn-detail"
              >
                詳細を見る &rarr;
              </a>
              {product.data.url && (
                <a
                  href={product.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-primary"
                >
                  体験する &rarr;
                </a>
              )}
              {product.data.repo && (
                <a
                  href={product.data.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-secondary"
                >
                  GitHub
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )
  }
</BaseLayout>

<style>
  .page-header {
    padding: 2rem 0 1rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .product-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .product-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s,
      background-color 0.3s;
  }

  .product-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--color-primary);
  }

  :global(.dark) .product-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .product-card-header {
    padding: 1.5rem 1.5rem 1rem;
  }

  .product-card-meta {
    margin-bottom: 0.75rem;
  }

  .status {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-active {
    background-color: rgba(34, 197, 94, 0.15);
    color: #16a34a;
  }

  :global(.dark) .status-active {
    color: #4ade80;
  }

  .status-beta {
    background-color: rgba(234, 179, 8, 0.15);
    color: #ca8a04;
  }

  .status-archived {
    background-color: rgba(107, 114, 128, 0.15);
    color: #6b7280;
  }

  .product-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .product-tagline {
    font-style: italic;
    color: var(--color-primary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .product-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .product-card-actions {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .btn-detail,
  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    background-image: none;
    transition: transform 0.25s, box-shadow 0.25s, background-color 0.25s,
      border-color 0.25s;
  }

  .btn-detail {
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
  }

  .btn-detail:hover {
    background-color: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px var(--color-primary-glow);
    color: white;
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-2px);
  }
</style>
