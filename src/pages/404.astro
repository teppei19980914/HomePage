---
// ============================================================
// 404.astro — カスタム 404 ページ
//
// 既存 URL (/profile/ 等) から /ja/profile/ への URL プレフィックス変更に伴い、
// 旧 URL へのアクセスが 404 になるユーザーへの案内ページ。
//
// 動作:
//   1. URL パスから古い形式のページ(/profile/, /blog/ など)を検出し、
//      対応する新 URL (/ja/profile/, /ja/blog/) へクライアントサイドリダイレクト
//   2. 検出できない場合は言語検出してトップへ誘導
//   3. JS 無効環境には meta refresh フォールバック
//
// セキュリティ:
//   - リダイレクト先は固定ホワイトリストのみ (任意文字列を受け付けない)
//   - rootUrl/localeUrl ヘルパー経由で URL を生成
// ============================================================
import { LOCALES, DEFAULT_LOCALE, getLabels } from "../i18n";
import { rootUrl, localeUrl } from "../i18n/url";

// 404 ページは言語未確定のため、デフォルトロケールの辞書を使用
const { site } = getLabels(DEFAULT_LOCALE);

const base = import.meta.env.BASE_URL;
const jaHref = rootUrl(`${DEFAULT_LOCALE}/`);
const localesJson = JSON.stringify(LOCALES);
const defaultLocale = DEFAULT_LOCALE;

// 旧 URL → 新 URL のマッピング(slug リスト)
// これらのパスに一致する場合、対応する /ja/ 配下へ自動リダイレクトする
const knownSlugs = [
  "profile",
  "product",
  "project",
  "blog",
  "contact",
];
const knownSlugsJson = JSON.stringify(knownSlugs);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found | {site.name}</title>
    <meta name="description" content="The page you're looking for could not be found." />
    <meta name="robots" content="noindex" />
    {/* JS 無効時のフォールバック: ja トップへ 3 秒後にリダイレクト */}
    <noscript>
      <meta http-equiv="refresh" content={`3; url=${jaHref}`} />
    </noscript>
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${base}favicon.svg`}
    />
    <style>
      body {
        background-color: #0f172a;
        color: #e2e8f0;
        font-family: "Yu Gothic UI", "Hiragino Sans", system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        padding: 1.5rem;
      }
      .container {
        max-width: 32rem;
        text-align: center;
      }
      h1 {
        font-size: 4rem;
        margin: 0 0 0.5rem;
        background: linear-gradient(135deg, #60a5fa, #a78bfa);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      h2 {
        font-size: 1.25rem;
        margin: 0 0 1.5rem;
        color: #e2e8f0;
      }
      p {
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.7;
        margin: 0 0 1rem;
      }
      .status {
        color: #60a5fa;
        font-size: 0.85rem;
        margin: 1.5rem 0;
      }
      .actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }
      .btn {
        display: inline-block;
        padding: 0.6rem 1.4rem;
        border-radius: 9999px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid #334155;
        color: #e2e8f0;
        background-color: #1e293b;
        transition: transform 0.2s, border-color 0.2s, color 0.2s;
      }
      .btn:hover {
        transform: translateY(-2px);
        border-color: #60a5fa;
        color: #60a5fa;
      }
      .btn.primary {
        background-color: #60a5fa;
        color: #0f172a;
        border-color: #60a5fa;
      }
      .btn.primary:hover {
        transform: translateY(-2px);
        background-color: #93c5fd;
        color: #0f172a;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>404</h1>
      <h2>Page Not Found / ページが見つかりません</h2>
      <p>
        The page you're looking for may have been moved to a new URL.<br />
        お探しのページは、新しい URL に移動している可能性があります。
      </p>
      <p class="status" id="redirectStatus"></p>
      <div class="actions">
        <a class="btn primary" href={localeUrl("ja", "")}>日本語トップ</a>
        <a class="btn primary" href={localeUrl("en", "")}>English Home</a>
      </div>
    </div>
    <script
      is:inline
      define:vars={{ base, jaHref, localesJson, knownSlugsJson, defaultLocale }}
    >
      (function () {
        var LOCALES = JSON.parse(localesJson);
        var KNOWN_SLUGS = JSON.parse(knownSlugsJson);
        var DEFAULT = defaultLocale;
        var status = document.getElementById("redirectStatus");

        function isSupported(loc) {
          return typeof loc === "string" && LOCALES.indexOf(loc) !== -1;
        }

        function detectLocale() {
          try {
            var saved = localStorage.getItem("preferred-locale");
            if (isSupported(saved)) return saved;
          } catch (e) {
            /* noop */
          }
          var browserLang = (navigator.language || "").toLowerCase().split("-")[0];
          if (isSupported(browserLang)) return browserLang;
          if (Array.isArray(navigator.languages)) {
            for (var i = 0; i < navigator.languages.length; i++) {
              var lang = (navigator.languages[i] || "").toLowerCase().split("-")[0];
              if (isSupported(lang)) return lang;
            }
          }
          return DEFAULT;
        }

        // 現在のパスから旧 URL を検出し、新 URL へリダイレクト
        // 例: /HomePage/profile/          → /HomePage/ja/profile/
        //     /HomePage/blog/hello-world/ → /HomePage/ja/blog/hello-world/
        var path = window.location.pathname;
        var basePath = base.replace(/\/$/, "");
        var relPath = path.indexOf(basePath) === 0 ? path.slice(basePath.length) : path;
        // 先頭スラッシュを剥がす
        relPath = relPath.replace(/^\/+/, "");
        // 既に言語プレフィックスがあればスキップ(リダイレクトループ防止)
        var firstSeg = relPath.split("/")[0];
        if (isSupported(firstSeg)) {
          // 本当に該当ページが存在しない(純粋な 404)のでリダイレクトしない
          if (status) status.textContent = "";
          return;
        }
        // 旧 URL の最初のセグメントが既知の slug なら対応する /{locale}/ 配下にリダイレクト
        if (KNOWN_SLUGS.indexOf(firstSeg) !== -1) {
          var locale = detectLocale();
          var target = basePath + "/" + locale + "/" + relPath;
          if (status) status.textContent = "Redirecting to " + target + " ...";
          setTimeout(function () {
            window.location.replace(target);
          }, 600);
        } else {
          // 未知のパス: 言語検出してトップへ誘導
          var locale2 = detectLocale();
          var target2 = basePath + "/" + locale2 + "/";
          if (status) status.textContent = "Redirecting to " + target2 + " ...";
          setTimeout(function () {
            window.location.replace(target2);
          }, 1500);
        }
      })();
    </script>
  </body>
</html>
