---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { blog } from "../../data/labels";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={blog.title} description={blog.description}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{blog.title}</h1>
    <p class="page-subtitle fade-in delay-1">{blog.subtitle}</p>
  </div>

  {
    posts.length === 0 ? (
      <p>{blog.emptyMessage}</p>
    ) : (
      <ul class="card-list">
        {posts.map((post, i) => (
          <li class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`} class="card">
              <span class="date">
                {post.data.date.toLocaleDateString("ja-JP")}
              </span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<style>
  .card {
    display: block;
    color: var(--color-text);
    background-image: none;
  }

  .card h3 {
    margin-top: 0.25rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
</style>
