---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { blog, blogToc, common } from "../../data/labels";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const workPostsAll = allPosts.filter((p) => p.data.category === "work");
const essayPostsAll = allPosts.filter((p) => p.data.category === "essay");
const workPosts = workPostsAll.slice(0, blog.maxPerSection);
const essayPosts = essayPostsAll.slice(0, blog.maxPerSection);
const hasMoreWork = workPostsAll.length > blog.maxPerSection;
const hasMoreEssay = essayPostsAll.length > blog.maxPerSection;

// Fetch Qiita articles at build time
interface QiitaArticle {
  title: string;
  url: string;
  created_at: string;
  likes_count: number;
  stocks_count: number;
  organization_url_name: string | null;
  tags: { name: string }[];
}

let qiitaArticles: QiitaArticle[] = [];
// dev サーバーでは毎リクエストで fetch が走ると遅いためスキップ。
// 本番ビルド時 (import.meta.env.PROD) のみ Qiita API を叩く。
if (import.meta.env.PROD) {
  try {
    const allItems: QiitaArticle[] = [];
    for (let page = 1; page <= 10; page++) {
      const res = await fetch(
        `https://qiita.com/api/v2/users/${blog.qiitaSection.qiitaUserId}/items?per_page=100&page=${page}`,
      );
      if (!res.ok) break;
      const data: QiitaArticle[] = await res.json();
      if (data.length === 0) break;
      allItems.push(...data);
      if (data.length < 100) break;
    }

    // 絞り込み: 直近1年以内 + Organization 未紐付け
    const oneYearAgo = new Date();
    oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);

    qiitaArticles = allItems
      .filter((item) => {
        if (new Date(item.created_at) < oneYearAgo) return false;
        if (item.organization_url_name !== null) return false;
        return true;
      })
      .map((item) => ({
        ...item,
        score: item.likes_count + item.stocks_count * 2,
      }))
      .sort((a, b) => b.score - a.score)
      .slice(0, blog.qiitaSection.maxArticles);
  } catch (e) {
    qiitaArticles = [];
  }
}

// 目次: 表示対象セクションのみ列挙
const tocItems = blogToc.filter((item) => {
  if (item.href === "#qiita") return qiitaArticles.length > 0;
  return true;
});
---

<BaseLayout title={blog.title} description={blog.description}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{blog.title}</h1>
    <p class="page-subtitle fade-in delay-1">{blog.subtitle}</p>
  </div>

  <!-- 目次 -->
  <nav class="toc reveal" aria-label={common.tocTitle}>
    <p class="toc-title">{common.tocTitle}</p>
    <ol class="toc-list">
      {tocItems.map((item, i) => (
        <li>
          <a href={item.href}>
            <span class="toc-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="toc-label">{item.label}</span>
            <span class="toc-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>

  <!-- Work & Dev Section -->
  <section id="work" class="section reveal">
    <h2>{blog.workSection.title}</h2>
    <p class="section-subtitle">{blog.workSection.subtitle}</p>
    {
      workPosts.length === 0 ? (
        <p class="empty-msg">{blog.workSection.emptyMessage}</p>
      ) : (
        <ul class="card-list">
          {workPosts.map((post, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.1}s`}>
              <a
                href={`${import.meta.env.BASE_URL}blog/${post.id}/`}
                class="card blog-card work-card"
                data-astro-reload
              >
                <div class="blog-card-header">
                  <span class="date">
                    {post.data.date.toLocaleDateString("ja-JP")}
                  </span>
                  <div class="tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    {hasMoreWork && (
      <p class="section-link">
        <a href={`${import.meta.env.BASE_URL}blog/category/work/`} data-astro-reload>
          {blog.viewAllText} &rarr;
        </a>
      </p>
    )}
  </section>

  <!-- Essay Section -->
  <section id="essay" class="section reveal">
    <h2>{blog.essaySection.title}</h2>
    <p class="section-subtitle">{blog.essaySection.subtitle}</p>
    {
      essayPosts.length === 0 ? (
        <p class="empty-msg">{blog.essaySection.emptyMessage}</p>
      ) : (
        <ul class="card-list">
          {essayPosts.map((post, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.1}s`}>
              <a
                href={`${import.meta.env.BASE_URL}blog/${post.id}/`}
                class="card blog-card essay-card"
                data-astro-reload
              >
                <div class="blog-card-header">
                  <span class="date">
                    {post.data.date.toLocaleDateString("ja-JP")}
                  </span>
                  <div class="tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    {hasMoreEssay && (
      <p class="section-link">
        <a href={`${import.meta.env.BASE_URL}blog/category/essay/`} data-astro-reload>
          {blog.viewAllText} &rarr;
        </a>
      </p>
    )}
  </section>

  <!-- Tech Blog (Qiita) Section -->
  {
    qiitaArticles.length > 0 && (
      <section id="qiita" class="section reveal">
        <h2>{blog.qiitaSection.title}</h2>
        <p class="section-subtitle">{blog.qiitaSection.subtitle}</p>
        <ul class="card-list">
          {qiitaArticles.map((article, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.05}s`}>
              <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="card qiita-card"
              >
                <div class="qiita-card-header">
                  <span class="date">
                    {new Date(article.created_at).toLocaleDateString("ja-JP")}
                  </span>
                  <div class="qiita-stats">
                    <span class="qiita-stat" title="いいね">
                      &#9829; {article.likes_count}
                    </span>
                    <span class="qiita-stat" title="ストック">
                      &#9733; {article.stocks_count}
                    </span>
                  </div>
                </div>
                <h3>{article.title}</h3>
                <div class="tags">
                  {article.tags.slice(0, 4).map((t) => (
                    <span class="tag">{t.name}</span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
        <p class="section-link">
          <a
            href={blog.qiitaSection.linkUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {blog.qiitaSection.linkText} &rarr;
          </a>
        </p>
      </section>
    )
  }
</BaseLayout>

<style>
  .section { margin-top: 2.5rem; scroll-margin-top: 5rem; }
  .section-subtitle { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }

  /* TOC */
  .toc {
    margin-top: 1.5rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    transition: background-color 0.3s, border-color 0.3s;
  }
  .toc-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 1.5rem;
  }
  @media (max-width: 640px) {
    .toc-list { grid-template-columns: 1fr; }
  }
  .toc-list li {
    border-bottom: 1px dashed var(--color-border);
  }
  .toc-list a {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 0.25rem;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 500;
    background-image: none;
    transition: color 0.2s, padding-left 0.2s;
  }
  .toc-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .toc-label { flex: 1; }
  .toc-arrow {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .toc-list a:hover {
    color: var(--color-primary);
    padding-left: 0.5rem;
  }
  .toc-list a:hover .toc-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-primary);
  }
  .section-link { text-align: right; margin-top: 1rem; }
  .section-link a { font-size: 0.9rem; font-weight: 600; }
  .empty-msg {
    padding: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 0.75rem;
    font-size: 0.9rem;
  }

  .card {
    display: block;
    color: var(--color-text);
    background-image: none;
  }
  .card h3 { margin-top: 0.25rem; }

  /* Blog card */
  .blog-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
  }

  /* Section-specific left borders */
  .work-card {
    border-left: 3px solid var(--color-primary);
  }
  .essay-card {
    border-left: 3px solid var(--color-accent);
  }
  .qiita-card {
    border-left: 3px solid #55c500;
  }

  .qiita-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .qiita-stats {
    display: flex;
    gap: 0.75rem;
  }
  .qiita-stat {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }
</style>
