---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CareerGraph from "../../components/CareerGraph.astro";
import { render } from "astro:content";
import { getLabels, normalizeLocale } from "../../i18n";
import { getLocalizedCollection, stripLocale } from "../../i18n/content";
import { localeUrl } from "../../i18n/url";
import { localeStaticPaths } from "../../i18n/paths";

export const getStaticPaths = localeStaticPaths;

const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
const { profile, about, site, common, profileToc, profileGroups } = t;

const socialLinks = [profile.links.github, profile.links.qiita, profile.links.wantedly];

// Profile ページの長文セクション (思想 / 方向性) を Content Collections から取得
const profileEntries = await getLocalizedCollection("profile", lang);

type ProfileEntry = (typeof profileEntries)[number];
type RenderedEntry = { entry: ProfileEntry; Content: Awaited<ReturnType<typeof render>>["Content"] };

async function renderGroup(group: "mindset" | "direction"): Promise<RenderedEntry[]> {
  const list = profileEntries
    .filter((e) => e.data.group === group)
    .sort((a, b) => a.data.order - b.data.order);
  return Promise.all(
    list.map(async (entry) => {
      const { Content } = await render(entry);
      return { entry, Content };
    }),
  );
}

const mindsetRendered = await renderGroup("mindset");
const directionRendered = await renderGroup("direction");

const birthDate = new Date(profile.birthDate);
const careerStart = new Date(profile.careerStartDate);
const now = new Date();

function calcYears(from: Date, to: Date): number {
  let years = to.getFullYear() - from.getFullYear();
  const monthDiff = to.getMonth() - from.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && to.getDate() < from.getDate())) {
    years--;
  }
  return years;
}

const age = calcYears(birthDate, now);
const careerYears = calcYears(careerStart, now);
---

<BaseLayout title={profile.title} description={profile.description}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{profile.title}</h1>
    <p class="page-subtitle fade-in delay-1">{profile.subtitle}</p>
  </div>

  <!-- 目次 -->
  <nav class="toc reveal" aria-label={common.tocTitle}>
    <p class="toc-title">{common.tocTitle}</p>
    <ol class="toc-list">
      {profileToc.map((item, i) => (
        <li>
          <a href={item.href}>
            <span class="toc-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="toc-label">{item.label}</span>
            <span class="toc-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>

  <!-- 基本情報 -->
  <section id="basic" class="section reveal">
    <div class="profile-card">
      <h2 class="profile-name">{profile.nameJa}<span class="profile-name-en">{profile.nameEn}</span></h2>
      <p class="profile-role">{site.role}</p>
      <div class="profile-grid">
        <div class="profile-item">
          <span class="profile-label">{profile.labels.birthDate}</span>
          <span class="profile-value">{profile.birthDateDisplay}</span>
        </div>
        <div class="profile-item">
          <span class="profile-label">{profile.labels.age}</span>
          <span class="profile-value">{age} {profile.labels.ageSuffix}</span>
        </div>
        <div class="profile-item">
          <span class="profile-label">{profile.labels.careerYears}</span>
          <span class="profile-value">{careerYears} {profile.labels.careerYearsSuffix}</span>
        </div>
        <div class="profile-item">
          <span class="profile-label">{profile.labels.location}</span>
          <span class="profile-value">{profile.location}</span>
        </div>
        <div class="profile-item">
          <span class="profile-label">{profile.labels.employer}</span>
          <span class="profile-value">
            <a href={profile.employer.url} target="_blank" rel="noopener noreferrer">{profile.employer.name}</a>
          </span>
        </div>
        <div class="profile-item">
          <span class="profile-label">{profile.labels.sideJob}</span>
          <span class="profile-value">
            <a href={profile.sideJob.url} target="_blank" rel="noopener noreferrer">{profile.sideJob.name}</a>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="section reveal">
    <h2 class="section-heading">{about.skills.title}</h2>
    <p class="skill-legend">{about.skills.legend}</p>
    <div class="skill-grid">
      <div class="skill-category">
        <h3>{about.skills.categories.languages}</h3>
        <ul>
          <li><span class="level-high">C#</span></li>
          <li><span class="level-high">JavaScript</span></li>
          <li><span class="level-high">Java</span></li>
          <li><span class="level-high">Python</span></li>
          <li><span class="level-high">PowerShell</span></li>
          <li><span class="level-mid">VBA</span></li>
          <li><span class="level-mid">HTML / CSS</span></li>
          <li><span class="level-low">PHP</span></li>
          <li><span class="level-low">ASP</span></li>
          <li><span class="level-low">Dart (個人開発)</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>{about.skills.categories.database}</h3>
        <ul>
          <li><span class="level-high">SQL Server</span></li>
          <li><span class="level-high">PostgreSQL</span></li>
          <li><span class="level-high">DB2</span></li>
          <li><span class="level-mid">MySQL</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>{about.skills.categories.cloud}</h3>
        <ul>
          <li><span class="level-high">Azure</span></li>
          <li><span class="level-high">AWS</span></li>
          <li><span class="level-mid">Power Platform (Apps / Automate)</span></li>
          <li><span class="level-mid">Azure DevOps</span></li>
          <li><span class="level-low">Dataverse</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>{about.skills.categories.os}</h3>
        <ul>
          <li><span class="level-high">Windows</span></li>
          <li><span class="level-mid">Linux (CentOS / Ubuntu / AlmaLinux / Red Hat)</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>{about.skills.categories.tools}</h3>
        <ul>
          <li><span class="level-high">VS Code / Eclipse</span></li>
          <li><span class="level-high">SSMS / pgAdmin / A5:SQL Mk-2</span></li>
          <li><span class="level-high">Postman / Wireshark / Autify</span></li>
          <li><span class="level-high">Redmine / Teams</span></li>
          <li><span class="level-high">IIS / VMware</span></li>
          <li><span class="level-mid">Docker / VirtualBox</span></li>
          <li><span class="level-mid">Apache</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>{about.skills.categories.personalDev}</h3>
        <ul>
          <li><span class="level-high">Flutter / Dart (Riverpod, Drift ORM, go_router)</span></li>
          <li><span class="level-mid">Astro / TypeScript</span></li>
          <li><span class="level-mid">Firebase (Auth, Firestore)</span></li>
          <li><span class="level-mid">GitHub Actions (CI/CD)</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications" class="section reveal">
    <h2 class="section-heading">{about.certifications.title}</h2>
    <ul class="cert-list">
      {about.certifications.items.map((cert) => (
        <li><span class="cert-date">{cert.date}</span>{cert.name}</li>
      ))}
    </ul>
  </section>

  <!-- Career -->
  <section id="career" class="section reveal">
    <h2 class="section-heading">{about.career.title}</h2>
    <CareerGraph locale={lang} />
  </section>

  <!-- Education -->
  <section id="education" class="section reveal">
    <h2 class="section-heading">{about.education.title}</h2>
    <div class="timeline">
      {about.education.items.map((edu) => (
        <div class="timeline-item">
          <span class="date">{edu.period}</span>
          <h3>{edu.name}</h3>
        </div>
      ))}
    </div>
  </section>

  <!-- Mindset (思想): Philosophy + Motto -->
  <section id="mindset" class="section reveal">
    <h2 class="section-heading">{profileGroups.mindset.title}</h2>
    <p class="group-lead">{profileGroups.mindset.lead}</p>
    {mindsetRendered.map(({ entry, Content }) => {
      const slug = stripLocale(entry.id) as keyof typeof profileGroups.mindset.sections;
      // サブセクション見出しはラベル辞書から取得(言語対応)。
      // マッピング未登録の場合は Markdown frontmatter の title にフォールバック。
      const subTitle = profileGroups.mindset.sections[slug] ?? entry.data.title;
      return (
        <article id={slug} class="profile-subsection">
          <h3 class="subsection-heading">{subTitle}</h3>
          <blockquote>{entry.data.quote}</blockquote>
          <div class="prose"><Content /></div>
        </article>
      );
    })}
  </section>

  <!-- Direction (方向性): Dream + Goal -->
  <section id="direction" class="section reveal">
    <h2 class="section-heading">{profileGroups.direction.title}</h2>
    <p class="group-lead">{profileGroups.direction.lead}</p>
    {directionRendered.map(({ entry, Content }) => {
      const slug = stripLocale(entry.id) as keyof typeof profileGroups.direction.sections;
      const subTitle = profileGroups.direction.sections[slug] ?? entry.data.title;
      return (
        <article id={slug} class="profile-subsection">
          <h3 class="subsection-heading">{subTitle}</h3>
          <blockquote>{entry.data.quote}</blockquote>
          <div class="prose"><Content /></div>
        </article>
      );
    })}
  </section>

  <!-- Links -->
  <section id="links" class="section reveal">
    <h2 class="section-heading">{profile.links.title}</h2>
    <div class="links-grid">
      {socialLinks.map((link) => (
        <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-card">
          <span class="link-name">{link.name}</span>
          <span class="link-id">{link.id}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bottom-cta reveal">
    <h2>{common.ctaTitle}</h2>
    <p>{common.ctaBody}</p>
    <a href={localeUrl(lang,"contact/")} class="btn-cta">{common.ctaButton}</a>
  </section>

</BaseLayout>

<style>
  .section {
    margin-top: 2.5rem;
    scroll-margin-top: 5rem;
  }
  .group-lead {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.75rem;
  }
  .profile-subsection {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-border);
    scroll-margin-top: 5rem;
  }
  .profile-subsection:first-of-type {
    border-top: none;
    padding-top: 0;
    margin-top: 0.5rem;
  }
  .subsection-heading {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }
  .section-heading {
    font-size: 1.35rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  /* TOC */
  .toc {
    margin-top: 1.5rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    transition: background-color 0.3s, border-color 0.3s;
  }
  .toc-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 1.5rem;
  }
  @media (max-width: 640px) {
    .toc-list { grid-template-columns: 1fr; }
  }
  .toc-list li {
    border-bottom: 1px dashed var(--color-border);
  }
  .toc-list a {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 0.25rem;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 500;
    background-image: none;
    transition: color 0.2s, padding-left 0.2s;
  }
  .toc-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .toc-label {
    flex: 1;
  }
  .toc-arrow {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .toc-list a:hover {
    color: var(--color-primary);
    padding-left: 0.5rem;
  }
  .toc-list a:hover .toc-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-primary);
  }

  /* Profile card */
  .profile-card { padding: 2rem; border: 1px solid var(--color-border); border-radius: 0.75rem; background-color: var(--color-surface); transition: background-color 0.3s; }
  .profile-name { font-size: 1.5rem; margin-bottom: 0.25rem; }
  .profile-name-en { font-size: 0.9rem; font-weight: 400; color: var(--color-text-muted); margin-left: 0.75rem; }
  .profile-role { font-size: 0.95rem; color: var(--color-accent); margin-bottom: 1.5rem; }
  .profile-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .profile-item { display: flex; justify-content: space-between; padding: 0.85rem 0; border-bottom: 1px solid var(--color-border); font-size: 0.9rem; gap: 2rem; }
  .profile-label { color: var(--color-text-muted); font-weight: 600; white-space: nowrap; }
  .profile-value { text-align: right; }

  /* Skills */
  .skill-legend { font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 1rem; }
  .skill-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; }
  .skill-category h3 { font-size: 1rem; margin-bottom: 0.5rem; }
  .skill-category ul { list-style: none; padding: 0; }
  .skill-category li { padding: 0.35rem 0; border-bottom: 1px solid var(--color-border); font-size: 0.875rem; }
  .level-high::before { content: "\25CF "; color: var(--color-accent); }
  .level-mid::before { content: "\25CB "; color: var(--color-accent); }
  .level-low::before { content: "\25B3 "; color: var(--color-text-muted); }

  /* Certifications */
  .cert-list { list-style: none; padding: 0; }
  .cert-list li { padding: 0.6rem 0; border-bottom: 1px solid var(--color-border); display: flex; align-items: center; gap: 0.75rem; }
  .cert-date { font-size: 0.75rem; color: var(--color-text-muted); background-color: var(--color-primary-glow); padding: 0.15rem 0.5rem; border-radius: 0.25rem; white-space: nowrap; min-width: 4.5rem; text-align: center; }

  /* Timeline */
  .timeline { display: flex; flex-direction: column; gap: 1.5rem; border-left: 2px solid var(--color-border); padding-left: 1.5rem; }
  .timeline-item { position: relative; }
  .timeline-item::before { content: ""; position: absolute; left: -1.75rem; top: 0.5rem; width: 0.5rem; height: 0.5rem; border-radius: 50%; background-color: var(--color-accent); }

  /* Blockquote */
  blockquote { border-left: 3px solid var(--color-accent); padding-left: 1rem; color: var(--color-text-muted); font-style: italic; }

  /* Links */
  .links-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; }
  .link-card { display: flex; flex-direction: column; align-items: center; padding: 1.25rem 1rem; border: 1px solid var(--color-border); border-radius: 0.75rem; background-color: var(--color-surface); background-image: none; color: var(--color-text); text-align: center; transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s; }
  .link-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); border-color: var(--color-primary); color: var(--color-text); }
  :global(.dark) .link-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
  .link-name { font-weight: 700; font-size: 1rem; margin-bottom: 0.25rem; }
  .link-id { font-size: 0.8rem; color: var(--color-text-muted); }

  /* Bottom CTA */
  .bottom-cta { margin-top: 2rem; padding: 2.5rem 1.5rem; text-align: center; border: 1px solid var(--color-border); border-radius: 0.75rem; background-color: var(--color-surface); }
  .bottom-cta h2 { margin-bottom: 0.5rem; }
  .bottom-cta p { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  .btn-cta { display: inline-block; padding: 0.75rem 2rem; border-radius: 9999px; background: linear-gradient(135deg, var(--color-primary), #8b5cf6); color: white; font-weight: 600; font-size: 0.95rem; background-image: none; transition: transform 0.25s, box-shadow 0.25s; }
  .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(--color-primary-glow); color: white; }
</style>
