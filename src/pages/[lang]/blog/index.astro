---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLabels, normalizeLocale, BCP47 } from "../../../i18n";
import { getLocalizedCollection, stripLocale, isVisibleInDev } from "../../../i18n/content";
import { localeUrl } from "../../../i18n/url";
import { localeStaticPaths } from "../../../i18n/paths";
import { estimateReadingTime } from "../../../utils/reading-time";

export const getStaticPaths = localeStaticPaths;

const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
import dynamicStats from "../../../data/dynamic-stats.json";

const { blog, common, readingTime: readingTimeLabel } = t;
const isDev = import.meta.env.DEV;

// 全記事を日付降順で取得
const allPosts = (await getLocalizedCollection("blog", lang))
  .filter(isVisibleInDev)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// ピックアップ記事の決定:
// 1. dynamic-stats.json の featuredSlugs（月次バッチで自動更新）を優先
// 2. featuredSlugs が空の場合、frontmatter の featured: true をフォールバック
const featuredSlugs: string[] = dynamicStats.featuredSlugs ?? [];
const featuredPosts = featuredSlugs.length > 0
  ? featuredSlugs
      .map((slug) => allPosts.find((p) => stripLocale(p.id) === slug))
      .filter((p): p is NonNullable<typeof p> => p != null)
  : allPosts.filter((p) => p.data.featured);

// 最新記事（ピックアップを除外）
const featuredIds = new Set(featuredPosts.map((p) => p.id));
const regularPosts = allPosts.filter((p) => !featuredIds.has(p.id));
const displayPosts = regularPosts.slice(0, blog.maxPerSection);
const hasMore = regularPosts.length > blog.maxPerSection;

// Fetch Qiita articles at build time
interface QiitaArticle {
  title: string;
  url: string;
  created_at: string;
  likes_count: number;
  stocks_count: number;
  organization_url_name: string | null;
  tags: { name: string }[];
}

let qiitaArticles: QiitaArticle[] = [];
// dev サーバーでは毎リクエストで fetch が走ると遅いためスキップ。
// 本番ビルド時 (import.meta.env.PROD) のみ Qiita API を叩く。
if (import.meta.env.PROD) {
  try {
    const allItems: QiitaArticle[] = [];
    for (let page = 1; page <= 10; page++) {
      const res = await fetch(
        `https://qiita.com/api/v2/users/${blog.qiitaSection.qiitaUserId}/items?per_page=100&page=${page}`,
      );
      if (!res.ok) break;
      const data: QiitaArticle[] = await res.json();
      if (data.length === 0) break;
      allItems.push(...data);
      if (data.length < 100) break;
    }

    const oneYearAgo = new Date();
    oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);

    qiitaArticles = allItems
      .filter((item) => {
        if (new Date(item.created_at) < oneYearAgo) return false;
        if (item.organization_url_name !== null) return false;
        return true;
      })
      .map((item) => ({
        ...item,
        score: item.likes_count + item.stocks_count * 2,
      }))
      .sort((a, b) => b.score - a.score)
      .slice(0, blog.qiitaSection.maxArticles);
  } catch (e) {
    qiitaArticles = [];
  }
}
---

<BaseLayout title={blog.title} description={blog.description}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{blog.title}</h1>
    <p class="page-subtitle fade-in delay-1">{blog.subtitle}</p>
  </div>

  <!-- Featured Section -->
  {featuredPosts.length > 0 && (
    <section class="section reveal">
      <h2 class="featured-heading">
        <span class="featured-icon">&#9733;</span>
        {blog.featuredSection.title}
      </h2>
      <p class="section-subtitle">{blog.featuredSection.subtitle}</p>
      <div class="featured-grid">
        {featuredPosts.map((post, i) => (
          <a
            href={localeUrl(lang, `blog/${stripLocale(post.id)}/`)}
            class="featured-card reveal"
            style={`transition-delay: ${i * 0.1}s`}
            data-astro-reload
          >
            <div class="featured-card-inner">
              <span class="featured-badge">{blog.featuredSection.title}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="featured-footer">
                <span class="date">
                  {post.data.date.toLocaleDateString(BCP47[lang])}
                </span>
                <div class="tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Blog Section -->
  <section class="section reveal">
    {
      displayPosts.length === 0 ? (
        <p class="empty-msg">{blog.emptyMessage}</p>
      ) : (
        <ul class="card-list">
          {displayPosts.map((post, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.1}s`}>
              <a
                href={localeUrl(lang, `blog/${stripLocale(post.id)}/`)}
                class="card blog-card"
                data-astro-reload
              >
                {isDev && post.data.draft && <span class="draft-badge">{blog.draftBanner}</span>}
                {isDev && !post.data.draft && post.data.date > new Date() && <span class="scheduled-badge">{blog.scheduledBanner}</span>}
                <h3>{post.data.title}</h3>
                <div class="card-meta">
                  <span class="date">{post.data.date.toLocaleDateString(BCP47[lang])}</span>
                  <span class="meta-divider"></span>
                  <span class="reading-time">{readingTimeLabel(estimateReadingTime(post.body ?? ""))}</span>
                  <span class="meta-divider"></span>
                  <span class="card-tags">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                    {post.data.tags.length > 4 && <span class="tag tag-more">+{post.data.tags.length - 4}</span>}
                  </span>
                </div>
                <p>{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    {hasMore && (
      <p class="section-link">
        <a href={localeUrl(lang, "blog/all/")} data-astro-reload>
          {blog.viewAllText} &rarr;
        </a>
      </p>
    )}
  </section>

  <!-- Tech Blog (Qiita) Section -->
  {
    qiitaArticles.length > 0 && (
      <section class="section reveal">
        <h2>{blog.qiitaSection.title}</h2>
        <p class="section-subtitle">{blog.qiitaSection.subtitle}</p>
        <ul class="card-list">
          {qiitaArticles.map((article, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.05}s`}>
              <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="card qiita-card"
              >
                <div class="qiita-card-header">
                  <span class="date">
                    {new Date(article.created_at).toLocaleDateString(BCP47[lang])}
                  </span>
                  <div class="qiita-stats">
                    <span class="qiita-stat" title="いいね">
                      &#9829; {article.likes_count}
                    </span>
                    <span class="qiita-stat" title="ストック">
                      &#9733; {article.stocks_count}
                    </span>
                  </div>
                </div>
                <h3>{article.title}</h3>
                <div class="tags">
                  {article.tags.slice(0, 4).map((t) => (
                    <span class="tag">{t.name}</span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
        <p class="section-link">
          <a
            href={blog.qiitaSection.linkUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {blog.qiitaSection.linkText} &rarr;
          </a>
        </p>
      </section>
    )
  }
</BaseLayout>

<style>
  .section { margin-top: 2.5rem; }
  .section-subtitle { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .section-link { text-align: right; margin-top: 1rem; }
  .section-link a { font-size: 0.9rem; font-weight: 600; }
  .draft-badge, .scheduled-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    width: 100%;
  }
  .draft-badge {
    background-color: rgba(234, 179, 8, 0.15);
    color: #ca8a04;
  }
  .scheduled-badge {
    background-color: rgba(59, 130, 246, 0.15);
    color: #2563eb;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
  }
  .meta-divider {
    width: 1px;
    height: 0.8rem;
    background-color: var(--color-border);
    flex-shrink: 0;
  }
  .card-tags {
    display: inline-flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .reading-time {
    color: var(--color-text-muted);
  }
  .empty-msg {
    padding: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 0.75rem;
    font-size: 0.9rem;
  }

  .card {
    display: block;
    color: var(--color-text);
    background-image: none;
  }
  .card h3 { margin-top: 0.25rem; }

  .card h3 { margin-bottom: 0.25rem; }

  .blog-card {
    border-left: 3px solid var(--color-primary);
  }
  .qiita-card {
    border-left: 3px solid #55c500;
  }

  .qiita-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .qiita-stats {
    display: flex;
    gap: 0.75rem;
  }
  .qiita-stat {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  /* Featured / Pickup */
  .featured-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .featured-icon {
    color: var(--color-accent);
    font-size: 1.2rem;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }
  .featured-card {
    display: block;
    border: 1px solid var(--color-accent);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    background-image: none;
    color: var(--color-text);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(139, 92, 246, 0.15);
    color: var(--color-text);
  }
  :global(.dark) .featured-card:hover {
    box-shadow: 0 8px 24px rgba(139, 92, 246, 0.25);
  }
  .featured-card-inner {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-top: 3px solid var(--color-accent);
  }
  .featured-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: white;
    width: fit-content;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .featured-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .featured-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    flex: 1;
    line-height: 1.6;
  }
  .featured-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
</style>
