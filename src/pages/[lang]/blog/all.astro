---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLabels, normalizeLocale, BCP47 } from "../../../i18n";
import { getLocalizedCollection, stripLocale, isPublished } from "../../../i18n/content";
import { localeUrl } from "../../../i18n/url";
import { localeStaticPaths } from "../../../i18n/paths";

export const getStaticPaths = localeStaticPaths;

const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
const { blog, common } = t;

const posts = (await getLocalizedCollection("blog", lang))
  .filter(isPublished)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`${blog.allTitle} | ${blog.title}`} description={blog.subtitle}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{blog.allTitle}</h1>
    <p class="page-subtitle fade-in delay-1">{blog.subtitle}</p>
  </div>

  <section class="section reveal">
    {
      posts.length === 0 ? (
        <p class="empty-msg">{blog.emptyMessage}</p>
      ) : (
        <ul class="card-list">
          {posts.map((post, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.05}s`}>
              <a
                href={localeUrl(lang, `blog/${stripLocale(post.id)}/`)}
                class="card blog-card"
                data-astro-reload
              >
                <div class="blog-card-header">
                  <span class="date">
                    {post.data.date.toLocaleDateString(BCP47[lang])}
                  </span>
                  <div class="tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    <p class="section-link">
      <a href={localeUrl(lang, "blog/")} data-astro-reload>&larr; {common.backLink}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .section { margin-top: 2.5rem; }
  .section-link { text-align: left; margin-top: 1.5rem; }
  .section-link a { font-size: 0.9rem; font-weight: 600; }
  .empty-msg {
    padding: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 0.75rem;
    font-size: 0.9rem;
  }
  .card { display: block; color: var(--color-text); background-image: none; }
  .card h3 { margin-top: 0.25rem; }
  .blog-card-header {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 0.25rem; flex-wrap: wrap;
  }
  .blog-card { border-left: 3px solid var(--color-primary); }
  .tags { display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap; }
</style>
