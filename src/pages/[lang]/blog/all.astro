---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLabels, normalizeLocale, BCP47 } from "../../../i18n";
import { getLocalizedCollection, stripLocale, isVisibleInDev } from "../../../i18n/content";
import { localeUrl } from "../../../i18n/url";
import { localeStaticPaths } from "../../../i18n/paths";
import { estimateReadingTime } from "../../../utils/reading-time";

export const getStaticPaths = localeStaticPaths;

const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
const { blog, common, readingTime: readingTimeLabel } = t;
const isDev = import.meta.env.DEV;

const posts = (await getLocalizedCollection("blog", lang))
  .filter(isVisibleInDev)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`${blog.allTitle} | ${blog.title}`} description={blog.allDescription}>
  <div class="page-header hero-gradient">
    <h1 class="fade-in">{blog.allTitle}</h1>
    <p class="page-subtitle fade-in delay-1">{blog.subtitle}</p>
  </div>

  <section class="section reveal">
    {
      posts.length === 0 ? (
        <p class="empty-msg">{blog.emptyMessage}</p>
      ) : (
        <ul class="card-list">
          {posts.map((post, i) => (
            <li class="reveal" style={`transition-delay: ${i * 0.05}s`}>
              <a
                href={localeUrl(lang, `blog/${stripLocale(post.id)}/`)}
                class="card blog-card"
                data-astro-reload
              >
                {isDev && post.data.draft && <span class="draft-badge">{blog.draftBanner}</span>}
                {isDev && !post.data.draft && post.data.date > new Date() && <span class="scheduled-badge">{blog.scheduledBanner}</span>}
                <h3>{post.data.title}</h3>
                <div class="card-meta">
                  <span class="date">{post.data.date.toLocaleDateString(BCP47[lang])}</span>
                  <span class="meta-divider"></span>
                  <span class="reading-time">{readingTimeLabel(estimateReadingTime(post.body ?? ""))}</span>
                  <span class="meta-divider"></span>
                  <span class="card-tags">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                    {post.data.tags.length > 4 && <span class="tag tag-more">+{post.data.tags.length - 4}</span>}
                  </span>
                </div>
                <p>{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    <p class="section-link">
      <a href={localeUrl(lang, "blog/")} data-astro-reload>&larr; {common.backLink}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .section { margin-top: 2.5rem; }
  .section-link { text-align: left; margin-top: 1.5rem; }
  .section-link a { font-size: 0.9rem; font-weight: 600; }
  .empty-msg {
    padding: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 0.75rem;
    font-size: 0.9rem;
  }
  .card { display: block; color: var(--color-text); background-image: none; }
  .card h3 { margin-bottom: 0.25rem; }
  .blog-card { border-left: 3px solid var(--color-primary); }
  .card-meta {
    display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
    font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 0.35rem;
  }
  .meta-divider { width: 1px; height: 0.8rem; background-color: var(--color-border); flex-shrink: 0; }
  .card-tags { display: inline-flex; gap: 0.3rem; flex-wrap: wrap; }
  .reading-time { color: var(--color-text-muted); }
  .draft-badge, .scheduled-badge {
    display: inline-block; font-size: 0.7rem; font-weight: 600;
    padding: 0.15rem 0.5rem; border-radius: 9999px; width: 100%;
  }
  .draft-badge { background-color: rgba(234, 179, 8, 0.15); color: #ca8a04; }
  .scheduled-badge { background-color: rgba(59, 130, 246, 0.15); color: #2563eb; }
</style>
