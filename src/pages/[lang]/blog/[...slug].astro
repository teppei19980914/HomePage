---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { getLabels, normalizeLocale, BCP47, LOCALES } from "../../../i18n";
import { getLocalizedCollection, stripLocale, isVisibleInDev } from "../../../i18n/content";
import { localeUrl } from "../../../i18n/url";
import { buildXShareUrl } from "../../../utils/share";
import { estimateReadingTime } from "../../../utils/reading-time";

export async function getStaticPaths() {
  const paths = [];
  for (const lang of LOCALES) {
    const posts = (await getLocalizedCollection("blog", lang)).filter(isVisibleInDev);
    for (const post of posts) {
      paths.push({
        params: { lang, slug: stripLocale(post.id) },
        props: { post },
      });
    }
  }
  return paths;
}

const { post } = Astro.props;
const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
const { common, share, blog, readingTime: readingTimeLabel } = t;
const readingMin = estimateReadingTime(post.body ?? "");
const { Content } = await render(post);
// dev 環境でのみ下書き/予約投稿バナーを表示（本番では表示しない）
const isDev = import.meta.env.DEV;
const isDraft = isDev && post.data.draft === true;
const isScheduled = isDev && !post.data.draft && post.data.date > new Date();

// シェア用 URL とテキストをビルド時に生成
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const shareText = `${post.data.title} | Teppei Suyama`;
const xShareUrl = buildXShareUrl(pageUrl, shareText);
const shareClipboardText = `${post.data.title} | Teppei Suyama\n${pageUrl}`;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedDate={post.data.date.toISOString()}
  tags={post.data.tags}
>
  {isDraft && (
    <div class="draft-banner">
      {blog.draftBanner}
    </div>
  )}
  {isScheduled && (
    <div class="scheduled-banner">
      {blog.scheduledBanner}
    </div>
  )}
  <article class="prose">
    <header class="hero-gradient fade-in">
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <span class="meta-item">
          <span class="meta-icon">&#128197;</span>
          {post.data.date.toLocaleDateString(BCP47[lang])}
        </span>
        <span class="meta-divider"></span>
        <span class="meta-item">
          <span class="meta-icon">&#9201;</span>
          {readingTimeLabel(readingMin)}
        </span>
        <span class="meta-divider"></span>
        <span class="meta-item meta-tags">
          {post.data.tags.slice(0, 4).map((tag) => <span class="tag">{tag}</span>)}
          {post.data.tags.length > 4 && <span class="tag tag-more">+{post.data.tags.length - 4}</span>}
        </span>
      </div>
    </header>

    <!-- モバイル: 折りたたみ目次 -->
    <nav class="toc-mobile reveal" aria-label={common.tocTitle}>
      <button class="toc-mobile-toggle" type="button" aria-expanded="false">
        <span class="toc-mobile-icon">&#9776;</span>
        <span>{common.tocTitle}</span>
        <span class="toc-mobile-chevron">&#9660;</span>
      </button>
      <ol class="toc-mobile-list" id="tocMobileList"></ol>
    </nav>

    <div class="blog-layout">
      <div class="content reveal">
        <Content />
      </div>

      <!-- PC: サイドバー固定目次 -->
      <aside class="toc-sidebar" aria-label={common.tocTitle}>
        <nav class="toc-sidebar-inner">
          <p class="toc-sidebar-title">{common.tocTitle}</p>
          <ol class="toc-sidebar-list" id="tocSidebarList"></ol>
        </nav>
      </aside>
    </div>
  </article>

  <!-- SNS シェアボタン -->
  <div class="share-section reveal">
    <p class="share-title">{share.title}</p>
    <div class="share-buttons">
      <a
        href={xShareUrl}
        target="_blank"
        rel="noopener"
        class="share-btn share-x"
        aria-label={share.x}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        <span>{share.x}</span>
      </a>
      <button
        class="share-btn share-text-copy"
        data-share-text={shareClipboardText}
        aria-label={share.copyText}
        data-label={share.copyText}
        data-copied={share.copied}
        type="button"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span>{share.copyText}</span>
      </button>
      <button
        class="share-btn share-copy"
        data-url={pageUrl}
        aria-label={share.copyLink}
        data-label={share.copyLink}
        data-copied={share.copied}
        type="button"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
        <span>{share.copyLink}</span>
      </button>
    </div>
  </div>

  <section class="bottom-cta reveal">
    <h2>{common.ctaTitle}</h2>
    <p>{common.ctaBody}</p>
    <a href={localeUrl(lang, "contact/")} class="btn-cta">{common.ctaButton}</a>
  </section>
  <nav class="back reveal">
    <a href="#" onclick="history.back(); return false;">&larr; {common.backLink}</a>
  </nav>

  <script is:inline>
    // コピーボタン共通ハンドラ
    function initShareCopy() {
      // シェア用テキストコピー（タイトル + URL）
      document.querySelectorAll(".share-text-copy").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var text = btn.getAttribute("data-share-text");
          var label = btn.getAttribute("data-label");
          var copied = btn.getAttribute("data-copied");
          var span = btn.querySelector("span");
          if (!text || !span) return;
          navigator.clipboard.writeText(text).then(function () {
            span.textContent = copied;
            btn.classList.add("copied");
            setTimeout(function () { span.textContent = label; btn.classList.remove("copied"); }, 2000);
          });
        });
      });
      // URL のみコピー
      document.querySelectorAll(".share-copy").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var url = btn.getAttribute("data-url");
          var label = btn.getAttribute("data-label");
          var copied = btn.getAttribute("data-copied");
          var span = btn.querySelector("span");
          if (!url || !span) return;
          navigator.clipboard.writeText(url).then(function () {
            span.textContent = copied;
            btn.classList.add("copied");
            setTimeout(function () { span.textContent = label; btn.classList.remove("copied"); }, 2000);
          });
        });
      });
    }
    initShareCopy();
    document.addEventListener("astro:after-swap", initShareCopy);

    // ===== 目次（TOC）の自動生成 =====
    function initToc() {
      var content = document.querySelector(".content");
      var mobileList = document.getElementById("tocMobileList");
      var sidebarList = document.getElementById("tocSidebarList");
      if (!content || (!mobileList && !sidebarList)) return;

      // 記事内の H2/H3 を取得（H4 以下は目次に含めない）
      var headings = content.querySelectorAll("h2, h3");
      if (headings.length === 0) {
        // 見出しがない記事では目次を非表示
        var tocMobile = document.querySelector(".toc-mobile");
        var tocSidebar = document.querySelector(".toc-sidebar");
        if (tocMobile) tocMobile.style.display = "none";
        if (tocSidebar) tocSidebar.style.display = "none";
        return;
      }

      var fragment1 = document.createDocumentFragment();
      var fragment2 = document.createDocumentFragment();
      var observeTargets = [];
      var h2Count = 0;
      var h3Count = 0;

      headings.forEach(function (h, i) {
        // id がない見出しにスラッグを付与
        if (!h.id) {
          h.id = "heading-" + i;
        }

        var text = (h.textContent || "").trim();
        if (!text) return; // 空の見出しはスキップ

        var isH3 = h.tagName === "H3";

        // 連番を算出
        var num;
        if (isH3) {
          h3Count++;
          num = h2Count + "." + h3Count;
        } else {
          h2Count++;
          h3Count = 0;
          num = String(h2Count);
        }

        observeTargets.push(h);

        function createTocItem(className) {
          var li = document.createElement("li");
          if (isH3) li.className = "toc-indent";
          var a = document.createElement("a");
          a.href = "#" + h.id;
          // 連番 + テキスト
          var numSpan = document.createElement("span");
          numSpan.className = "toc-num";
          numSpan.textContent = num;
          var labelSpan = document.createElement("span");
          labelSpan.className = "toc-label";
          labelSpan.textContent = text;
          a.appendChild(numSpan);
          a.appendChild(labelSpan);
          if (className) a.setAttribute("data-heading-id", h.id);
          li.appendChild(a);
          return li;
        }

        // モバイル用
        if (mobileList) {
          var li1 = createTocItem(null);
          li1.querySelector("a").addEventListener("click", function () {
            var toggle = document.querySelector(".toc-mobile-toggle");
            var list = document.getElementById("tocMobileList");
            if (toggle && list) {
              toggle.setAttribute("aria-expanded", "false");
              list.classList.remove("is-open");
            }
          });
          fragment1.appendChild(li1);
        }

        // サイドバー用
        if (sidebarList) {
          fragment2.appendChild(createTocItem("sidebar"));
        }
      });

      if (mobileList) mobileList.appendChild(fragment1);
      if (sidebarList) sidebarList.appendChild(fragment2);

      // モバイル: 折りたたみトグル
      var toggleBtn = document.querySelector(".toc-mobile-toggle");
      if (toggleBtn && mobileList) {
        toggleBtn.addEventListener("click", function () {
          var isOpen = toggleBtn.getAttribute("aria-expanded") === "true";
          toggleBtn.setAttribute("aria-expanded", isOpen ? "false" : "true");
          mobileList.classList.toggle("is-open", !isOpen);
        });
      }

      // PC: Intersection Observer で現在位置をハイライト
      if (sidebarList && observeTargets.length > 0 && typeof IntersectionObserver !== "undefined") {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var links = sidebarList.querySelectorAll("a");
            links.forEach(function (link) {
              link.classList.toggle(
                "is-active",
                link.getAttribute("data-heading-id") === entry.target.id
              );
            });
          });
        }, { rootMargin: "-80px 0px -60% 0px", threshold: 0 });

        observeTargets.forEach(function (target) {
          observer.observe(target);
        });
      }
    }
    initToc();
    document.addEventListener("astro:after-swap", initToc);

  </script>
</BaseLayout>

<style>
  .draft-banner {
    background-color: rgba(234, 179, 8, 0.15);
    color: #ca8a04;
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .scheduled-banner {
    background-color: rgba(59, 130, 246, 0.15);
    color: #2563eb;
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  header {
    margin-bottom: 2rem;
  }
  header h1 {
    margin-bottom: 0.75rem;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.6rem 0;
    border-top: 1px solid var(--color-border);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .meta-icon {
    font-size: 0.85rem;
    line-height: 1;
  }
  .meta-divider {
    width: 1px;
    height: 0.9rem;
    background-color: var(--color-border);
    flex-shrink: 0;
  }
  .meta-tags {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .content {
    margin-top: 2rem;
    min-width: 0; /* flex child のオーバーフロー防止 */
  }

  /* ===== Blog Layout (PC: サイドバー付き 2カラム) ===== */
  .blog-layout {
    display: flex;
    gap: 2rem;
  }
  .blog-layout .content {
    flex: 1;
    min-width: 0;
  }

  /* ===== Mobile TOC (折りたたみ) ===== */
  .toc-mobile {
    margin-top: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    overflow: hidden;
  }
  .toc-mobile-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    background: none;
    border: none;
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.2s;
  }
  .toc-mobile-toggle:hover { color: var(--color-primary); }
  .toc-mobile-icon { font-size: 0.9rem; }
  .toc-mobile-chevron {
    margin-left: auto;
    font-size: 0.6rem;
    transition: transform 0.3s;
  }
  .toc-mobile-toggle[aria-expanded="true"] .toc-mobile-chevron {
    transform: rotate(180deg);
  }
  .toc-mobile-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: none;
    border-top: 1px solid var(--color-border);
  }
  .toc-mobile-list.is-open { display: block; }
  .toc-mobile-list li a {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    background-image: none;
    transition: color 0.2s, background-color 0.2s;
  }
  .toc-mobile-list li a:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-glow);
  }
  .toc-mobile-list .toc-indent a { padding-left: 2rem; font-size: 0.78rem; }
  .toc-mobile-list .toc-num {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    min-width: 1.5rem;
  }
  .toc-mobile-list .toc-label { flex: 1; }

  /* ===== Sidebar TOC (PC: sticky) ===== */
  .toc-sidebar {
    display: none; /* デフォルト非表示、PC のみ表示 */
    width: 220px;
    flex-shrink: 0;
  }
  .toc-sidebar-inner {
    position: sticky;
    top: 4rem; /* ヘッダーの高さ分 */
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
    scrollbar-width: thin;
  }
  .toc-sidebar-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .toc-sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-sidebar-list li a {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.35rem 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-image: none;
    border-left: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    line-height: 1.4;
  }
  .toc-sidebar-list .toc-num {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-accent);
    min-width: 1.2rem;
  }
  .toc-sidebar-list .toc-label { flex: 1; }
  .toc-sidebar-list li a:hover {
    color: var(--color-primary);
  }
  .toc-sidebar-list li a.is-active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    font-weight: 600;
  }
  .toc-sidebar-list .toc-indent a {
    padding-left: 1.75rem;
    font-size: 0.72rem;
    opacity: 0.85;
  }

  /* ===== レスポンシブ ===== */
  @media (min-width: 1080px) {
    .toc-mobile { display: none; }
    .toc-sidebar { display: block; }
    /* ブログ記事ページだけ main の幅を拡張（サイドバー分） */
    :global(main) { max-width: 1080px; }
  }
  @media (max-width: 1079px) {
    .blog-layout { flex-direction: column; }
    .toc-sidebar { display: none; }
  }

  /* Share buttons */
  .share-section {
    margin-top: 3rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    text-align: center;
  }
  .share-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .share-buttons {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background-color: transparent;
    background-image: none;
    color: var(--color-text);
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, color 0.2s, background-color 0.2s;
  }
  .share-btn:hover {
    transform: translateY(-2px);
  }
  .share-x:hover {
    border-color: #1d9bf0;
    color: #1d9bf0;
  }
  .share-text-copy:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .share-text-copy.copied {
    border-color: #22c55e;
    color: #22c55e;
  }
  .share-copy:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .share-copy.copied {
    border-color: #22c55e;
    color: #22c55e;
  }

  .back {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .bottom-cta { margin-top: 3rem; padding: 2.5rem 1.5rem; text-align: center; border: 1px solid var(--color-border); border-radius: 0.75rem; background-color: var(--color-surface); }
  .bottom-cta h2 { margin-bottom: 0.5rem; }
  .bottom-cta p { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  .btn-cta { display: inline-block; padding: 0.75rem 2rem; border-radius: 9999px; background: linear-gradient(135deg, var(--color-primary), #8b5cf6); color: white; font-weight: 600; background-image: none; transition: transform 0.25s, box-shadow 0.25s; }
  .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(--color-primary-glow); color: white; }
</style>
