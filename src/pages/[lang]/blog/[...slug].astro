---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { getLabels, normalizeLocale, BCP47, LOCALES } from "../../../i18n";
import { getLocalizedCollection, stripLocale, isVisibleInDev } from "../../../i18n/content";
import { localeUrl } from "../../../i18n/url";
import { buildXShareUrl, buildFbShareUrl } from "../../../utils/share";

export async function getStaticPaths() {
  const paths = [];
  for (const lang of LOCALES) {
    const posts = (await getLocalizedCollection("blog", lang)).filter(isVisibleInDev);
    for (const post of posts) {
      paths.push({
        params: { lang, slug: stripLocale(post.id) },
        props: { post },
      });
    }
  }
  return paths;
}

const { post } = Astro.props;
const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
const { common, share, blog } = t;
const { Content } = await render(post);
const isDraft = post.data.draft === true;

// シェア用 URL とテキストをビルド時に生成
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const shareText = `${post.data.title} | Teppei Suyama`;
const xShareUrl = buildXShareUrl(pageUrl, shareText);
const fbShareUrl = buildFbShareUrl(pageUrl);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedDate={post.data.date.toISOString()}
  tags={post.data.tags}
>
  {isDraft && (
    <div class="draft-banner">
      {blog.draftBanner}
    </div>
  )}
  <article class="prose">
    <header class="hero-gradient fade-in">
      <span class="date">{post.data.date.toLocaleDateString(BCP47[lang])}</span>
      <h1>{post.data.title}</h1>
      <div class="tags">
        {post.data.tags.slice(0, 4).map((tag) => <span class="tag">{tag}</span>)}
        {post.data.tags.length > 4 && <span class="tag tag-more">+{post.data.tags.length - 4}</span>}
      </div>
    </header>
    <div class="content reveal">
      <Content />
    </div>
  </article>

  <!-- SNS シェアボタン -->
  <div class="share-section reveal">
    <p class="share-title">{share.title}</p>
    <div class="share-buttons">
      <a
        href={xShareUrl}
        target="_blank"
        rel="noopener"
        class="share-btn share-x"
        aria-label={share.x}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        <span>{share.x}</span>
      </a>
      <a
        href={fbShareUrl}
        target="_blank"
        rel="noopener"
        class="share-btn share-fb"
        aria-label={share.facebook}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        <span>{share.facebook}</span>
      </a>
      <button
        class="share-btn share-copy"
        data-url={pageUrl}
        aria-label={share.copyLink}
        data-label={share.copyLink}
        data-copied={share.copied}
        type="button"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span>{share.copyLink}</span>
      </button>
    </div>
  </div>

  <section class="bottom-cta reveal">
    <h2>{common.ctaTitle}</h2>
    <p>{common.ctaBody}</p>
    <a href={localeUrl(lang, "contact/")} class="btn-cta">{common.ctaButton}</a>
  </section>
  <nav class="back reveal">
    <a href="#" onclick="history.back(); return false;">&larr; {common.backLink}</a>
  </nav>

  <script is:inline>
    // リンクコピーボタン
    function initShareCopy() {
      var btns = document.querySelectorAll(".share-copy");
      btns.forEach(function (btn) {
        btn.addEventListener("click", function () {
          var url = btn.getAttribute("data-url");
          var label = btn.getAttribute("data-label");
          var copied = btn.getAttribute("data-copied");
          var span = btn.querySelector("span");
          if (!url || !span) return;
          navigator.clipboard.writeText(url).then(function () {
            span.textContent = copied;
            btn.classList.add("copied");
            setTimeout(function () {
              span.textContent = label;
              btn.classList.remove("copied");
            }, 2000);
          });
        });
      });
    }
    initShareCopy();
    document.addEventListener("astro:after-swap", initShareCopy);
  </script>
</BaseLayout>

<style>
  .draft-banner {
    background-color: rgba(234, 179, 8, 0.15);
    color: #ca8a04;
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  header {
    margin-bottom: 2rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .content {
    margin-top: 2rem;
  }

  /* Share buttons */
  .share-section {
    margin-top: 3rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background-color: var(--color-surface);
    text-align: center;
  }
  .share-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .share-buttons {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background-color: transparent;
    background-image: none;
    color: var(--color-text);
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, color 0.2s, background-color 0.2s;
  }
  .share-btn:hover {
    transform: translateY(-2px);
  }
  .share-x:hover {
    border-color: #1d9bf0;
    color: #1d9bf0;
  }
  .share-fb:hover {
    border-color: #1877f2;
    color: #1877f2;
  }
  .share-copy:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .share-copy.copied {
    border-color: #22c55e;
    color: #22c55e;
  }

  .back {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .bottom-cta { margin-top: 3rem; padding: 2.5rem 1.5rem; text-align: center; border: 1px solid var(--color-border); border-radius: 0.75rem; background-color: var(--color-surface); }
  .bottom-cta h2 { margin-bottom: 0.5rem; }
  .bottom-cta p { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  .btn-cta { display: inline-block; padding: 0.75rem 2rem; border-radius: 9999px; background: linear-gradient(135deg, var(--color-primary), #8b5cf6); color: white; font-weight: 600; background-image: none; transition: transform 0.25s, box-shadow 0.25s; }
  .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(--color-primary-glow); color: white; }
</style>
