---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLabels, normalizeLocale, BCP47 } from "../../i18n";
import { getLocalizedCollection, stripLocale, isPublished } from "../../i18n/content";
import { localeUrl } from "../../i18n/url";
import { localeStaticPaths } from "../../i18n/paths";
import { estimateReadingTime } from "../../utils/reading-time";

export const getStaticPaths = localeStaticPaths;

const lang = normalizeLocale(Astro.params.lang);
const t = getLabels(lang);
const { home, site, readingTime: readingTimeLabel } = t;

// 月次バッチで更新される動的データ(update-stats.yml が自動更新)
import dynamicStats from "../../data/dynamic-stats.json";

// Home の Blog セクションはアクセス数ベースのピックアップ記事を表示する。
// dynamic-stats.json の featuredSlugs(Cloudflare Analytics から月次自動更新)を
// 優先し、該当記事が未公開 or 空の場合は frontmatter の featured: true にフォールバック。
const publishedPosts = (await getLocalizedCollection("blog", lang))
  .filter(isPublished)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredSlugsForHome: string[] = dynamicStats.featuredSlugs ?? [];
const pickupFromStats = featuredSlugsForHome
  .map((slug) => publishedPosts.find((p) => stripLocale(p.id) === slug))
  .filter((p): p is NonNullable<typeof p> => p != null);

const recentPosts = (
  pickupFromStats.length > 0
    ? pickupFromStats
    : publishedPosts.filter((p) => p.data.featured)
).slice(0, 4);

const products = (await getLocalizedCollection("product", lang))
  .sort((a, b) => a.data.order - b.data.order);

const heroSummaryText = [
  home.heroSummary.engineerYears(dynamicStats.engineerYears),
  home.heroSummary.qiitaArticles(dynamicStats.qiita.itemsCount),
  home.heroSummary.personalDev,
].join(home.heroSummary.separator);
---

<BaseLayout title="Home" description={site.defaultDescription}>
  <!-- ===== 1. Hero ===== -->
  <section class="hero hero-gradient">
    <h1 class="hero-name fade-in">
      <span class="highlight">{site.name}</span>
    </h1>
    <p class="hero-tagline fade-in delay-1">{home.heroTagline}</p>
    <p class="hero-summary fade-in delay-2">{heroSummaryText}</p>
    <div class="hero-cta fade-in delay-3">
      <a href={localeUrl(lang,"contact/")} class="btn-primary-hero">
        {home.contact.linkText}
      </a>
    </div>
  </section>

  <!-- ===== 2. 実績ハイライト ===== -->
  <section class="stats reveal">
    <div class="stats-grid">
      {home.stats.map((s) => (
        <a href={localeUrl(lang,s.link)} class="stat-item stat-link">
          <span class="stat-number">{s.number}</span>
          <span class="stat-unit">{s.unit}</span>
          <span class="stat-label">{s.label}</span>
          <span class="stat-detail">{s.detail}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== 3. 強み ===== -->
  <section class="section reveal">
    <h2>{home.strengths.title}</h2>
    <div class="strengths-grid">
      {home.strengths.items.map((item, i) => (
        <div class="strength-card reveal" style={`transition-delay: ${i * 0.1}s`}>
          <span class="strength-num">{`0${i + 1}`}</span>
          <h3>{item.heading}</h3>
          <p>{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 4. プロダクト ===== -->
  <section class="section reveal">
    <h2>{home.productCards.title}</h2>
    <p class="section-desc">{home.productCards.desc}</p>
    <div class="product-grid">
      {products.filter((p) => p.data.status !== "beta").map((p, i) => (
        <a
          href={localeUrl(lang,`product/${stripLocale(p.id)}/`)}
          class="product-card reveal"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <div class="product-color" style="background:linear-gradient(135deg,#06b6d4,#2563eb)"></div>
          <div class="product-body">
            <h3>{p.data.title}</h3>
            <p class="product-tagline">{p.data.tagline}</p>
            <p class="product-desc">{p.data.description}</p>
            <div class="product-tags">
              {p.data.tags.slice(0, 4).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
      {products.filter((p) => p.data.status === "beta").map((p, i) => (
        <a
          href={localeUrl(lang,`product/${stripLocale(p.id)}/`)}
          class="product-card product-coming-soon reveal"
          style={`transition-delay: ${(i + 1) * 0.1}s`}
        >
          <div class="product-color" style="background:linear-gradient(135deg,#8b5cf6,#2563eb)"></div>
          <div class="product-body">
            <span class="product-beta-badge">開発中 — こうご期待</span>
            <h3>{p.data.title}</h3>
            <p class="product-tagline">{p.data.tagline}</p>
            <p class="product-desc">{p.data.description}</p>
            <div class="product-tags">
              {p.data.tags.slice(0, 4).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== 5. ブログ ===== -->
  {recentPosts.length > 0 && (
    <section class="section reveal">
      <h2>{home.blog.title}</h2>
      <p class="section-desc">{home.blog.desc}</p>
      <ul class="blog-list">
        {recentPosts.map((post, i) => (
          <li class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <a href={localeUrl(lang,`blog/${stripLocale(post.id)}/`)} class="blog-item" data-astro-reload>
              <h3 class="blog-title">{post.data.title}</h3>
              <div class="blog-meta">
                <span class="blog-date">{post.data.date.toLocaleDateString(BCP47[lang])}</span>
                <span class="blog-meta-divider"></span>
                <span class="blog-reading-time">{readingTimeLabel(estimateReadingTime(post.body ?? ""))}</span>
                <span class="blog-meta-divider"></span>
                <span class="blog-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                  {post.data.tags.length > 3 && <span class="tag tag-more">+{post.data.tags.length - 3}</span>}
                </span>
              </div>
              <p class="blog-desc">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
      <p class="section-link">
        <a href={localeUrl(lang,"blog/")} data-astro-reload>{home.blog.linkText} &rarr;</a>
      </p>
    </section>
  )}

  <!-- ===== 6. Profile ===== -->
  <section class="section reveal">
    <h2>{home.profileSection.title}</h2>
    <p class="section-desc">{home.profileSection.desc}</p>
    <p class="section-link">
      <a href={localeUrl(lang,"profile/")}>{home.profileSection.linkText} &rarr;</a>
    </p>
  </section>

  <!-- ===== 7. CTA ===== -->
  <section class="bottom-cta reveal">
    <h2>{home.contact.title}</h2>
    <p>{home.contact.desc}</p>
    <a href={localeUrl(lang,"contact/")} class="btn-primary-hero">
      {home.contact.linkText}
    </a>
  </section>
</BaseLayout>

<style>
  /* Hero (Home ページ限定でより動きのある背景) */
  .hero { padding: 5rem 0 4rem; text-align: center; position: relative; }

  /* Home hero はデフォルトの .hero-gradient より強めの動きにする(他ページには影響させない) */
  .hero.hero-gradient::before {
    animation:
      meshMove 9s ease-in-out infinite alternate,
      heroPulse 6s ease-in-out infinite;
    opacity: 0.9;
  }

  @keyframes heroPulse {
    0%, 100% { filter: saturate(1) brightness(1); }
    50% { filter: saturate(1.25) brightness(1.08); }
  }

  .hero-name {
    font-size: clamp(2.25rem, 7vw, 3.75rem);
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .highlight {
    background: linear-gradient(135deg, var(--color-primary), #8b5cf6, #ec4899, var(--color-primary));
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: highlightShift 8s ease-in-out infinite;
  }
  @keyframes highlightShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .hero-tagline {
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    color: var(--color-text);
    margin-bottom: 1rem;
    font-weight: 600;
    line-height: 1.6;
  }
  .hero-summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    letter-spacing: 0.03em;
  }
  .hero-cta { display: flex; justify-content: center; }

  /* ダークモードで tagline を読みやすく調整 */
  :global(.dark) .hero-tagline { color: var(--color-text); }

  /* モーションを嫌うユーザーに配慮 */
  @media (prefers-reduced-motion: reduce) {
    .hero.hero-gradient::before { animation: none; }
    .highlight { animation: none; background-position: 0% 50%; }
  }
  .btn-primary-hero {
    display: inline-block; padding: 0.75rem 2rem; border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-primary), #8b5cf6); color: white;
    font-weight: 600; font-size: 0.95rem; background-image: none;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .btn-primary-hero:hover { transform: translateY(-2px); box-shadow: 0 6px 20px var(--color-primary-glow); color: white; }

  /* Stats */
  .stats { margin-top: 3rem; padding: 2rem 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; text-align: center; }
  .stat-item { display: flex; flex-direction: column; align-items: center; }
  .stat-number { font-size: clamp(2rem, 5vw, 2.75rem); font-weight: 800; background: linear-gradient(135deg, var(--color-primary), #8b5cf6); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; line-height: 1; }
  .stat-unit { font-size: 0.85rem; color: var(--color-text-muted); margin-top: 0.1rem; }
  .stat-label { font-size: 0.8rem; font-weight: 600; color: var(--color-text); margin-top: 0.35rem; }
  .stat-detail { font-size: 0.7rem; color: var(--color-text-muted); margin-top: 0.2rem; line-height: 1.4; }
  .stat-link { text-decoration: none; background-image: none; border-radius: 0.75rem; padding: 1rem 0.5rem; border: 1px solid transparent; transition: background-color 0.25s, transform 0.25s, border-color 0.25s; }
  .stat-link:hover { background-color: var(--color-primary-glow); border-color: var(--color-border); transform: translateY(-2px); }
  @media (max-width: 600px) { .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }

  /* Section */
  .section { margin-top: 3.5rem; }
  .section-desc { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.8; margin-bottom: 1.5rem; }
  .section-link { text-align: right; margin-top: 1rem; margin-bottom: 0; }
  .section-link a { font-size: 0.9rem; font-weight: 600; }

  /* Strengths */
  .strengths-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; margin-top: 1rem; }
  .strength-card {
    padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 0.75rem;
    background-color: var(--color-surface); transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s, background-color 0.3s;
  }
  .strength-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); border-color: var(--color-accent); }
  :global(.dark) .strength-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .strength-num { font-size: 0.75rem; font-weight: 700; color: var(--color-accent); letter-spacing: 0.05em; }
  .strength-card h3 { font-size: 1rem; margin-top: 0.35rem; margin-bottom: 0.5rem; }
  .strength-card p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 0; }

  /* Product cards */
  .product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .product-card {
    display: flex; flex-direction: column; border: 1px solid var(--color-border); border-radius: 0.75rem;
    background-color: var(--color-surface); overflow: hidden; color: var(--color-text); background-image: none;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .product-coming-soon { opacity: 0.55; filter: grayscale(0.55); }
  .product-coming-soon:hover { opacity: 0.85; filter: grayscale(0.25); }
  .product-beta-badge { display: inline-block; font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 9999px; background-color: rgba(234,179,8,0.15); color: #ca8a04; margin-bottom: 0.5rem; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); border-color: var(--color-primary); color: var(--color-text); }
  :global(.dark) .product-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .product-color { height: 4px; width: 100%; }
  .product-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
  .product-body h3 { font-size: 1.15rem; margin-bottom: 0.25rem; }
  .product-tagline { font-size: 0.85rem; font-style: italic; color: var(--color-accent); margin-bottom: 0.5rem; }
  .product-desc { font-size: 0.85rem; color: var(--color-text-muted); flex: 1; }
  .product-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.75rem; }

  /* Blog */
  .blog-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 0; }
  .blog-item {
    display: block; padding: 1rem 1.25rem; border: 1px solid var(--color-border); border-radius: 0.75rem;
    background-color: var(--color-surface); background-image: none; color: var(--color-text);
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .blog-item:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.08); border-color: var(--color-primary); color: var(--color-text); }
  :global(.dark) .blog-item:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
  .blog-title { font-size: 1rem; margin-bottom: 0.25rem; }
  .blog-meta {
    display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
    font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 0.35rem;
  }
  .blog-date { }
  .blog-reading-time { }
  .blog-meta-divider { width: 1px; height: 0.8rem; background-color: var(--color-border); flex-shrink: 0; }
  .blog-tags { display: inline-flex; gap: 0.3rem; flex-wrap: wrap; }
  .blog-desc { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0; }

  /* Bottom CTA */
  .bottom-cta {
    margin-top: 4rem; padding: 3rem 2rem; text-align: center;
    border: 1px solid var(--color-border); border-radius: 0.75rem;
    background-color: var(--color-surface); transition: background-color 0.3s;
  }
  .bottom-cta h2 { margin-bottom: 0.5rem; }
  .bottom-cta p { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
</style>
