---
import BaseLayout from "../layouts/BaseLayout.astro";
import CareerGraph from "../components/CareerGraph.astro";
---

<BaseLayout title="About" description="須山 哲平（Teppei Suyama）のプロフィール">
  <div class="page-header hero-gradient">
    <h1 class="fade-in">About</h1>
    <p class="page-subtitle fade-in delay-1">須山 哲平 / Teppei Suyama</p>
  </div>

  <section class="section reveal">
    <h2>Profile</h2>
    <p>
      須山 哲平（Teppei Suyama）。川崎在住のソフトウェアエンジニア。
    </p>
    <p>
      株式会社LTS ソフトウェアテクノロジーにて SES エンジニアとして従事。
      前職ではローコード開発プラットフォーム「Pleasanter」の開発・導入支援に携わり、
      Qiita にて 211 件以上の技術記事を発信しています。
    </p>
    <p>
      個人では Flutter / Dart を用いたモバイル・Web アプリ開発に取り組み、
      夢や目標を管理するアプリ「ユメログ」を個人開発しています。
    </p>
    <blockquote>
      「落ちこぼれでも必死に努力すればエリートを超えることもあるかもよ」<br />
      塵も積もれば山となる。1.01 の法則を信じて日々努力を積み重ねています。
    </blockquote>
  </section>

  <section class="section reveal">
    <h2>Philosophy</h2>
    <div class="philosophy-card">
      <h3>「夢を持つことで、大きな壁も乗り越えられる」</h3>
      <ul class="philosophy-list">
        <li>夢は外に出し、脳に認識させる必要がある ── 言霊の力を信じています</li>
        <li>人は慣性で行動する。動いている人は動き続け、止まっている人は止まり続ける</li>
        <li>止まっている人を動かし、動いている人を支える ── それが自分のものづくりの原点</li>
        <li>他者に依存せず、自分の力で世界をよりよくするという信念</li>
      </ul>
      <p class="vision">
        <strong>最終目標:</strong> 心理的安全性の高い社会の構築
      </p>
    </div>
  </section>

  <section class="section reveal">
    <h2>Skills</h2>
    <p class="skill-legend">&#9679; 実務2年以上　&#9675; 実務1年以上　&#9651; 知識あり</p>
    <div class="skill-grid">
      <div class="skill-category">
        <h3>Languages</h3>
        <ul>
          <li><span class="level-high">C#</span></li>
          <li><span class="level-high">JavaScript</span></li>
          <li><span class="level-high">Java</span></li>
          <li><span class="level-high">Python</span></li>
          <li><span class="level-high">PowerShell</span></li>
          <li><span class="level-mid">VBA</span></li>
          <li><span class="level-mid">HTML / CSS</span></li>
          <li><span class="level-low">PHP</span></li>
          <li><span class="level-low">ASP</span></li>
          <li><span class="level-low">Dart (個人開発)</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Database</h3>
        <ul>
          <li><span class="level-high">SQL Server</span></li>
          <li><span class="level-high">PostgreSQL</span></li>
          <li><span class="level-high">DB2</span></li>
          <li><span class="level-mid">MySQL</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Cloud / Platform</h3>
        <ul>
          <li><span class="level-high">Azure</span></li>
          <li><span class="level-high">AWS</span></li>
          <li><span class="level-mid">Power Platform (Apps / Automate)</span></li>
          <li><span class="level-mid">Azure DevOps</span></li>
          <li><span class="level-low">Dataverse</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>OS</h3>
        <ul>
          <li><span class="level-high">Windows</span></li>
          <li><span class="level-mid">Linux (CentOS / Ubuntu / AlmaLinux / Red Hat)</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Tools</h3>
        <ul>
          <li><span class="level-high">VS Code / Eclipse</span></li>
          <li><span class="level-high">SSMS / pgAdmin / A5:SQL Mk-2</span></li>
          <li><span class="level-high">Postman / Wireshark / Autify</span></li>
          <li><span class="level-high">Redmine / Teams</span></li>
          <li><span class="level-high">IIS / VMware</span></li>
          <li><span class="level-mid">Docker / VirtualBox</span></li>
          <li><span class="level-mid">Apache</span></li>
        </ul>
      </div>
      <div class="skill-category">
        <h3>Personal Dev</h3>
        <ul>
          <li><span class="level-high">Flutter / Dart (Riverpod, Drift ORM, go_router)</span></li>
          <li><span class="level-mid">Astro / TypeScript</span></li>
          <li><span class="level-mid">Firebase (Auth, Firestore)</span></li>
          <li><span class="level-mid">GitHub Actions (CI/CD)</span></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section reveal">
    <h2>Certifications</h2>
    <ul class="cert-list">
      <li><span class="cert-date">2026.02</span>Python 3 エンジニア認定実践試験</li>
      <li><span class="cert-date">2024.10</span>応用情報技術者試験</li>
      <li><span class="cert-date">2024.03</span>OSS-DB Silver</li>
      <li><span class="cert-date">2023.11</span>AZ-900 (Microsoft Azure Fundamentals)</li>
      <li><span class="cert-date">2023.09</span>LPIC Level 1</li>
      <li><span class="cert-date">2022.11</span>基本情報技術者試験</li>
      <li><span class="cert-date">2021.07</span>Oracle Certified Java Programmer, Gold SE 11</li>
      <li><span class="cert-date">2019.07</span>MOS Excel 2019 Expert</li>
      <li><span class="cert-date">2018.06</span>日本語漢字能力検定 2級</li>
    </ul>
  </section>

  <section class="section reveal">
    <h2>Career</h2>
    <CareerGraph />
  </section>

  <section class="section reveal">
    <h2>Education</h2>
    <div class="timeline">
      <div class="timeline-item">
        <span class="date">2017年4月 - 2021年3月</span>
        <h3>東京福祉大学 心理学部心理学科</h3>
      </div>
      <div class="timeline-item">
        <span class="date">2014年4月 - 2017年3月</span>
        <h3>目黒学院高等学校</h3>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    padding: 2rem 0 1rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .section {
    margin-top: 2.5rem;
  }

  blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .skill-legend {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .skill-category h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .skill-category ul {
    list-style: none;
    padding: 0;
  }

  .skill-category li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .level-high::before {
    content: "\25CF ";
    color: var(--color-primary);
  }

  .level-mid::before {
    content: "\25CB ";
    color: var(--color-primary);
  }

  .level-low::before {
    content: "\25B3 ";
    color: var(--color-text-muted);
  }

  .cert-list {
    list-style: none;
    padding: 0;
  }

  .cert-list li {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cert-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-color: var(--color-primary-glow);
    padding: 0.15rem 0.5rem;
    border-radius: 0.25rem;
    white-space: nowrap;
    min-width: 4.5rem;
    text-align: center;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-left: 2px solid var(--color-border);
    padding-left: 1.5rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-item::before {
    content: "";
    position: absolute;
    left: -1.75rem;
    top: 0.5rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .philosophy-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-surface);
  }

  .philosophy-card h3 {
    color: var(--color-primary);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .philosophy-list {
    list-style: none;
    padding: 0;
  }

  .philosophy-list li {
    padding: 0.4rem 0;
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .vision {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background-color: var(--color-bg);
    border-radius: 0.375rem;
    font-size: 1rem;
  }
</style>
