---
// ============================================================
// index.astro — 言語検出リダイレクトページ
//
// このページは /HomePage/ にアクセスされた際に表示され、
// ユーザーの localStorage 設定または navigator.language に基づいて
// 適切な言語ページへクライアントサイドでリダイレクトする。
//
// セキュリティ:
//   - リダイレクト先は固定のホワイトリスト ("ja" / "en") のみ
//   - navigator.language は信頼せず、必ず LOCALES に含まれるか検証
//   - 不正値・未対応言語は全て DEFAULT_LOCALE (ja) にフォールバック
//
// フォールバック:
//   1. localStorage の preferred-locale
//   2. navigator.language から言語コード抽出
//   3. 上記いずれも取得できない/不正 → ja
//
// JS 無効環境:
//   <noscript> + meta refresh で ja にリダイレクト
// ============================================================
import { LOCALES, DEFAULT_LOCALE } from "../i18n";
import { rootUrl } from "../i18n/url";

const baseHref = rootUrl("");
const jaHref = rootUrl(`${DEFAULT_LOCALE}/`);
// ホワイトリストを JSON 化してクライアントに渡す(任意文字列の locale を許容しない)
const localesJson = JSON.stringify(LOCALES);
const defaultLocale = DEFAULT_LOCALE;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Teppei Suyama</title>
    <meta name="description" content="Teppei Suyama - Software Engineer Portfolio" />
    {/* noindex は使わない: canonical で /ja/ を正規 URL として宣言すれば
         重複コンテンツ問題は解決され、Google Search Console の
         「noindex タグによって除外」エラーも回避できる。 */}
    {/* JS 無効時のフォールバック: 0秒で ja にリダイレクト */}
    <noscript>
      <meta http-equiv="refresh" content={`0; url=${jaHref}`} />
    </noscript>
    <link rel="canonical" href={jaHref} />
    {/* 言語選択ページとして hreflang を明示(多言語サイトの標準パターン) */}
    <link rel="alternate" hreflang="ja" href={jaHref} />
    <link rel="alternate" hreflang="en" href={rootUrl("en/")} />
    <link rel="alternate" hreflang="x-default" href={jaHref} />
    <style>
      body {
        background-color: #0f172a;
        color: #e2e8f0;
        font-family: "Yu Gothic UI", system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
      }
      .detecting {
        text-align: center;
        opacity: 0.8;
      }
      .detecting a {
        color: #60a5fa;
        margin: 0 0.5rem;
      }
    </style>
  </head>
  <body>
    <div class="detecting">
      <p>Detecting your language / 言語を判定中...</p>
      <p>
        <a href={rootUrl("ja/")}>日本語</a> /
        <a href={rootUrl("en/")}>English</a>
      </p>
    </div>
    <script is:inline define:vars={{ baseHref, localesJson, defaultLocale }}>
      (function () {
        var LOCALES = JSON.parse(localesJson);
        var DEFAULT = defaultLocale;

        function isSupported(loc) {
          return typeof loc === "string" && LOCALES.indexOf(loc) !== -1;
        }

        function detectLocale() {
          // 1. localStorage の明示設定を最優先
          try {
            var saved = localStorage.getItem("preferred-locale");
            if (isSupported(saved)) return saved;
          } catch (e) {
            /* SecurityError(iframe 埋め込み等) は無視 */
          }

          // 2. navigator.language から言語コードを抽出 ("ja-JP" → "ja")
          var browserLang = (navigator.language || "").toLowerCase().split("-")[0];
          if (isSupported(browserLang)) return browserLang;

          // 3. navigator.languages を順にチェック
          if (Array.isArray(navigator.languages)) {
            for (var i = 0; i < navigator.languages.length; i++) {
              var lang = (navigator.languages[i] || "").toLowerCase().split("-")[0];
              if (isSupported(lang)) return lang;
            }
          }

          // 4. どれもマッチしなければデフォルトへフォールバック
          return DEFAULT;
        }

        var target = baseHref + detectLocale() + "/";
        // replace() を使ってブラウザ履歴を汚さない(戻るで無限ループを防ぐ)
        window.location.replace(target);
      })();
    </script>
  </body>
</html>
